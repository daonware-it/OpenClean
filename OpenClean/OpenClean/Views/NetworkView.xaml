<UserControl x:Class="OpenClean.Views.NetworkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="clr-namespace:OpenClean.Services.Localization"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="960"
             Background="{DynamicResource BgBrush}"
             FontFamily="{StaticResource AppFont}">
    <UserControl.Resources>
        <!-- Suchfeld -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Height" Value="38" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                CornerRadius="10" Padding="12,0">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Segment-Button (Sortierung) -->
        <Style x:Key="SegmentButton" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                CornerRadius="{TemplateBinding Tag}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="32,10,32,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Loc network.title}"
                       Style="{StaticResource HeaderText}" FontSize="24"
                       VerticalAlignment="Center" Margin="0,0,16,0" />
            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                       Text="{loc:Loc network.subtitle}" TextWrapping="Wrap"
                       Style="{StaticResource MutedText}" Margin="0,4,0,0" />

            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal"
                        HorizontalAlignment="Right" VerticalAlignment="Center">
                <!-- Suche -->
                <Grid Width="210" VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBox x:Name="SearchBox" Style="{StaticResource SearchBoxStyle}"
                             Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="{loc:Loc network.searchPlaceholder}" IsHitTestVisible="False"
                               Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Sortierung -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <RadioButton Style="{StaticResource SegmentButton}" GroupName="NetSort" Tag="8,0,0,8"
                                 Content="{loc:Loc network.sort.process}"
                                 IsChecked="{Binding IsSortProcess, Mode=OneWay}"
                                 Command="{Binding SortByProcessCommand}" />
                    <RadioButton Style="{StaticResource SegmentButton}" GroupName="NetSort" Tag="0" Margin="-1,0,0,0"
                                 Content="{loc:Loc network.sort.remote}"
                                 IsChecked="{Binding IsSortRemote, Mode=OneWay}"
                                 Command="{Binding SortByRemoteCommand}" />
                    <RadioButton Style="{StaticResource SegmentButton}" GroupName="NetSort" Tag="0,8,8,0" Margin="-1,0,0,0"
                                 Content="{loc:Loc network.sort.state}"
                                 IsChecked="{Binding IsSortState, Mode=OneWay}"
                                 Command="{Binding SortByStateCommand}" />
                </StackPanel>

                <Button Style="{StaticResource SecondaryButton}" VerticalAlignment="Center"
                        Command="{Binding RefreshCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"
                              Fill="{x:Null}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Data="M23 4 v6 h-6 M1 20 v-6 h6 M3.51 9 a9 9 0 0 1 14.85 -3.36 L23 10 M1 17 l4.64 4.36 A9 9 0 0 0 20.49 15" />
                        <TextBlock Text="{loc:Loc common.refresh}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ===== Umschalter ===== -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,18,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,24,0">
                <ToggleButton Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"
                              IsChecked="{Binding ExternalOnly, Mode=TwoWay}"
                              ToolTip="{loc:Loc network.filter.externalOnly.tooltip}" />
                <TextBlock Text="{loc:Loc network.filter.externalOnly}" Margin="10,0,0,0"
                           VerticalAlignment="Center" FontSize="12.5" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ToggleButton Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"
                              IsChecked="{Binding ResolveHostNames, Mode=TwoWay}"
                              ToolTip="{loc:Loc network.filter.resolveHosts.tooltip}" />
                <TextBlock Text="{loc:Loc network.filter.resolveHosts}" Margin="10,0,0,0"
                           VerticalAlignment="Center" FontSize="12.5" />
            </StackPanel>
        </StackPanel>

        <!-- ===== Spaltenkopf ===== -->
        <Border Grid.Row="2" Margin="0,18,0,0" Padding="18,10" CornerRadius="8,8,0,0"
                Background="{DynamicResource BgDeepBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{loc:Loc network.col.process}" Style="{StaticResource MutedText}"
                           FontSize="10.5" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="{loc:Loc network.col.remote}" Style="{StaticResource MutedText}"
                           FontSize="10.5" FontWeight="SemiBold" />
                <TextBlock Grid.Column="2" Text="{loc:Loc network.col.local}" Style="{StaticResource MutedText}"
                           FontSize="10.5" FontWeight="SemiBold" />
                <TextBlock Grid.Column="3" Text="{loc:Loc network.col.protocol}" Style="{StaticResource MutedText}"
                           FontSize="10.5" FontWeight="SemiBold" />
                <TextBlock Grid.Column="4" Text="{loc:Loc network.col.state}" Style="{StaticResource MutedText}"
                           FontSize="10.5" FontWeight="SemiBold" HorizontalAlignment="Right" />
            </Grid>
        </Border>

        <!-- ===== Liste ===== -->
        <Border Grid.Row="3" Style="{StaticResource Card}" CornerRadius="0,0,10,10"
                BorderThickness="1,0,1,1">
            <ListBox ItemsSource="{Binding ConnectionsView}"
                     Background="Transparent" BorderThickness="0" Padding="6,4"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingStackPanel.IsVirtualizing="True"
                     VirtualizingStackPanel.VirtualizationMode="Recycling">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <!-- Container reicht nur durch: kein Auswahl-/Fokus-Highlight;
                             Hover und Abstände liefert die Zeile im DataTemplate selbst. -->
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter HorizontalAlignment="Stretch" />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="row" Background="Transparent" CornerRadius="8"
                                    Padding="12,11" Margin="0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Programm: echtes Icon, sonst farbiger Buchstaben-Avatar -->
                                    <Grid Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid Grid.Column="0" Width="34" Height="34" Margin="0,0,12,0"
                                              VerticalAlignment="Center">
                                            <Border CornerRadius="8" Background="{Binding InitialBrush}"
                                                    Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                                                <TextBlock Text="{Binding Initial}" Foreground="White" FontWeight="Bold"
                                                           FontSize="15" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                            <Image Source="{Binding Icon}" Width="30" Height="30"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}}" />
                                        </Grid>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding ProcessDisplay}" FontSize="14"
                                                           FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding ProcessIdDisplay}" Margin="8,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Style="{StaticResource MutedText}" FontSize="10.5"
                                                           FontFamily="{StaticResource MonoFont}" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding PathDisplay}" Style="{StaticResource MutedText}"
                                                       FontSize="11.5" Margin="0,3,0,0"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding PathDisplay}" />
                                        </StackPanel>
                                    </Grid>

                                    <!-- Ziel: Adresse:Port, darunter der aufgelöste Hostname -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding RemoteDisplay}" FontSize="12.5"
                                                       FontFamily="{StaticResource MonoFont}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding RemoteDisplay}" />
                                            <!-- Kennzeichnet Verbindungen, die den Rechner nicht verlassen -->
                                            <Border CornerRadius="5" Padding="6,1" Margin="8,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Background="{DynamicResource SurfaceBrush}"
                                                    Visibility="{Binding IsLocalOnly, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="{loc:Loc network.badge.local}" FontSize="9"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource TextMutedBrush}" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding HostName}" Style="{StaticResource MutedText}"
                                                   FontSize="11" Margin="0,3,0,0"
                                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding HostName}"
                                                   Visibility="{Binding HasHostName, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>

                                    <!-- Lokaler Endpunkt -->
                                    <TextBlock Grid.Column="2" Text="{Binding LocalDisplay}"
                                               VerticalAlignment="Center" FontSize="12"
                                               FontFamily="{StaticResource MonoFont}"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextTrimming="CharacterEllipsis" ToolTip="{Binding LocalDisplay}"
                                               Margin="0,0,12,0" />

                                    <!-- Protokoll -->
                                    <TextBlock Grid.Column="3" Text="{Binding ProtocolDisplay}"
                                               VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextMutedBrush}" />

                                    <!-- Zustand: nur ESTABLISHED wird als „aktiv" hervorgehoben -->
                                    <Border Grid.Column="4" HorizontalAlignment="Right" VerticalAlignment="Center"
                                            CornerRadius="11" Padding="12,5">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background"
                                                                Value="{DynamicResource AccentSoftBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="{DynamicResource TextMutedBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Text="{Binding StateDisplay}" Margin="8,0,0,0" FontSize="11.5"
                                                       FontWeight="SemiBold" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground"
                                                                Value="{DynamicResource TextMutedBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Foreground"
                                                                        Value="{DynamicResource AccentBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True" SourceName="row">
                                    <Setter TargetName="row" Property="Background"
                                            Value="{DynamicResource SurfaceHoverBrush}" />
                                </Trigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
        </Border>

        <!-- ===== Statusleiste ===== -->
        <Border Grid.Row="4" Background="{DynamicResource BgDeepBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Margin="-32,14,-32,0" Padding="32,12">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{Binding StatusText}" Style="{StaticResource MutedText}" FontSize="12.5" />
                <TextBlock Text="{loc:Loc network.note.readOnly}"
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="10.5" Opacity="0.75" Margin="0,3,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
