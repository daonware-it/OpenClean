<UserControl x:Class="OpenClean.Views.CleanerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:OpenClean.Views"
             xmlns:conv="clr-namespace:OpenClean.Converters"
             xmlns:loc="clr-namespace:OpenClean.Services.Localization"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900"
             Background="{DynamicResource BgBrush}"
             FontFamily="{DynamicResource AppFont}">
    <Grid Margin="32,10,32,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <Grid Grid.Row="0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{loc:Loc cleaner.title}" Style="{StaticResource HeaderText}" FontSize="24" />
                <TextBlock Text="{loc:Loc cleaner.subtitle}"
                           Style="{StaticResource MutedText}" Margin="0,4,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Style="{StaticResource SecondaryButton}" Command="{Binding ScanCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"
                              Fill="{x:Null}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Data="M11 5 a6 6 0 1 0 0 12 a6 6 0 1 0 0 -12 Z M20.5 20.5 L15.8 15.8" />
                        <TextBlock Text="{loc:Loc common.analyze}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource PrimaryButton}" Command="{Binding CleanCommand}" Margin="12,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M6 2 L18 2 L18 6 L6 6 Z M8 6 L16 6 L15 21 L9 21 Z" />
                        <TextBlock Text="{loc:Loc common.clean}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ===== Tab-Leiste ===== -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,20,0,0">
            <Button Content="{loc:Loc largefiles.categoriesTab}"
                    Command="{Binding ShowCategoriesCommand}"
                    Padding="16,8" FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                    BorderThickness="0,0,0,2" Background="Transparent">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCategoriesTab}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="{loc:Loc largefiles.tab}"
                    Command="{Binding ShowLargeFilesCommand}"
                    Padding="16,8" FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                    BorderThickness="0,0,0,2" Background="Transparent" Margin="8,0,0,0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLargeFilesTab}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- ===== Inhalt: je nach Tab ===== -->
        <Grid Grid.Row="2" Margin="0,4,0,0">
            <local:CleanupCategoriesView
                Visibility="{Binding IsCategoriesTab, Converter={StaticResource BoolToVis}}" />
            <local:LargeFilesView DataContext="{Binding LargeFiles}"
                Visibility="{Binding DataContext.IsLargeFilesTab,
                             RelativeSource={RelativeSource AncestorType=UserControl},
                             Converter={StaticResource BoolToVis}}" />
        </Grid>

        <!-- ===== Status + progress bar (Kategorien-Tab) ===== -->
        <Border Grid.Row="3" Background="{DynamicResource BgDeepBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Margin="-32,14,-32,0" Padding="32,12"
                Visibility="{Binding IsCategoriesTab, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <!-- Live-Fortschritt der Analyse: aktueller Pfad + Prozent + Restzeit -->
                <Grid Margin="0,0,0,8"
                      Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding ScanProgressText}"
                               Style="{StaticResource MutedText}" FontSize="12"
                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ScanProgressPercent, StringFormat={}{0:0} %}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center" Margin="12,0,0,0" />
                        <TextBlock Text="{Binding ScanEtaText}" Style="{StaticResource MutedText}"
                                   FontSize="12" VerticalAlignment="Center" Margin="14,0,0,0" />
                    </StackPanel>
                </Grid>
                <ProgressBar Minimum="0" Maximum="100" Value="{Binding ScanProgressPercent, Mode=OneWay}"
                             Height="6" Margin="0,0,0,8"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                <TextBlock Text="{Binding StatusText}" Style="{StaticResource MutedText}"
                           FontSize="12.5" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- ===== Status + progress bar (Große-Dateien-Tab) ===== -->
        <Border Grid.Row="3" Background="{DynamicResource BgDeepBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Margin="-32,14,-32,0" Padding="32,12"
                DataContext="{Binding LargeFiles}"
                Visibility="{Binding DataContext.IsLargeFilesTab,
                             RelativeSource={RelativeSource AncestorType=UserControl},
                             Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <!-- Live-Fortschritt der Datei-Suche: aktueller Pfad + Prozent (keine Restzeit) -->
                <Grid Margin="0,0,0,8"
                      Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding ScanProgressText}"
                               Style="{StaticResource MutedText}" FontSize="12"
                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ScanProgressPercent, StringFormat={}{0:0} %}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center" Margin="12,0,0,0" />
                    </StackPanel>
                </Grid>
                <ProgressBar Minimum="0" Maximum="100" Value="{Binding ScanProgressPercent, Mode=OneWay}"
                             Height="6" Margin="0,0,0,8"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                <TextBlock Text="{Binding StatusText}" Style="{StaticResource MutedText}"
                           FontSize="12.5" VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
