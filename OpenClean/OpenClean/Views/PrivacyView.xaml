<UserControl x:Class="OpenClean.Views.PrivacyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:OpenClean.Views"
             xmlns:loc="clr-namespace:OpenClean.Services.Localization"
             xmlns:ctl="clr-namespace:OpenClean.Controls"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900"
             Background="{DynamicResource BgBrush}"
             FontFamily="{DynamicResource AppFont}">
    <UserControl.Resources>
        <!-- Eingabefeld der Cookie-Whitelist -->
        <Style x:Key="WhitelistInputStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Height" Value="38" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                CornerRadius="10" Padding="12,0">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid Margin="32,10,32,0">
        <!-- Kopfzeile und Statusleiste bleiben fest stehen; ALLES dazwischen liegt in genau
             einem seitenweiten ScrollViewer (Zeile 1). Frueher war der obere Block eine
             Auto-Zeile: er wuchs mit seinem Inhalt und quetschte die Kategorien-Zeile auf
             wenige Pixel zusammen, sodass „Browser-Verlauf" unerreichbar war. -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <Grid Grid.Row="0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{loc:Loc privacy.title}" Style="{StaticResource HeaderText}" FontSize="24" />
                <TextBlock Text="{loc:Loc privacy.subtitle}"
                           Style="{StaticResource MutedText}" Margin="0,4,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Style="{StaticResource SecondaryButton}" Command="{Binding ScanCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"
                              Fill="{x:Null}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Data="M11 5 a6 6 0 1 0 0 12 a6 6 0 1 0 0 -12 Z M20.5 20.5 L15.8 15.8" />
                        <TextBlock Text="{loc:Loc common.analyze}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource PrimaryButton}" Command="{Binding CleanCommand}" Margin="12,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M6 2 L18 2 L18 6 L6 6 Z M8 6 L16 6 L15 21 L9 21 Z" />
                        <TextBlock Text="{loc:Loc common.clean}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ===== Seiten-ScrollViewer: einziger Scroll-Container der Seite ===== -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,0">
        <StackPanel>

            <!-- Ergebnis-Banner nach dem Bereinigen -->
            <Border Margin="0,22,0,0" Padding="20,14" CornerRadius="10"
                    Background="{DynamicResource AccentBrush}"
                    Visibility="{Binding HasReport, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"
                          Stroke="{DynamicResource OnAccentBrush}" StrokeThickness="2.5" Data="M 0,6 L 5,11 L 14,0"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                    <TextBlock Text="{Binding LastReportText}" Margin="14,0,0,0" VerticalAlignment="Center"
                               Foreground="{DynamicResource OnAccentBrush}" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Auswahl-Zusammenfassung -->
            <Border Style="{StaticResource Card}" Margin="0,22,0,0" Padding="22,18" ClipToBounds="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <!-- Dezenter Akzent-Glow -->
                    <Rectangle Grid.ColumnSpan="2" Margin="-22,-18" Fill="{DynamicResource HeroGlowBrush}"
                               IsHitTestVisible="False" />
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{loc:Loc privacy.selectedLabel}" Style="{StaticResource MutedText}"
                                   FontSize="11.5" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SelectionSummary}" FontSize="19" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                    <Border Grid.Column="1" Background="{DynamicResource BgDeepBrush}" CornerRadius="8"
                            Padding="18,12" VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc privacy.entries}" Style="{StaticResource MutedText}" FontSize="11"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding SelectedCount}" Style="{StaticResource MetricText}" FontSize="24" FontWeight="Bold"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Cookie-Whitelist: geschützte Domains verwalten -->
            <Border Style="{StaticResource Card}" Margin="0,22,0,0" Padding="22,18">
                <StackPanel>
                    <TextBlock Text="{loc:Loc privacy.whitelist.title}" FontSize="14.5" FontWeight="SemiBold" />
                    <TextBlock Text="{loc:Loc privacy.whitelist.description}" Style="{StaticResource MutedText}"
                               TextWrapping="Wrap" Margin="0,4,0,0" />

                    <!-- Eingabezeile -->
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <TextBox x:Name="WhitelistInput" Style="{StaticResource WhitelistInputStyle}"
                                     Text="{Binding NewWhitelistDomain, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding AddWhitelistCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>
                            <TextBlock Text="{loc:Loc privacy.whitelist.placeholder}" IsHitTestVisible="False"
                                       Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=WhitelistInput}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <Button Grid.Column="1" Content="{loc:Loc privacy.whitelist.add}"
                                Style="{StaticResource SecondaryButton}" Margin="10,0,0,0"
                                Command="{Binding AddWhitelistCommand}" />
                    </Grid>

                    <!-- Leerzustand -->
                    <TextBlock Text="{loc:Loc privacy.whitelist.empty}" Style="{StaticResource MutedText}"
                               Margin="0,12,0,0"
                               Visibility="{Binding WhitelistDomains.Count, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />

                    <!-- Liste der geschützten Domains -->
                    <ItemsControl ItemsSource="{Binding WhitelistDomains}" Margin="0,12,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding}" FontSize="13"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding}" />
                                    <Button Grid.Column="1" Content="{loc:Loc privacy.whitelist.remove}"
                                            Style="{StaticResource SecondaryButton}" Padding="12,6" FontSize="12.5"
                                            Command="{Binding DataContext.RemoveWhitelistCommand,
                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Vorhandene Cookies: Inventar mit „+" je Domain -->
            <Border Style="{StaticResource Card}" Margin="0,22,0,0" Padding="22,18">
                <StackPanel>
                    <!-- Kopfzeile mit Titel/Beschreibung links und Lade-Button rechts -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{loc:Loc privacy.browserCookies.title}" FontSize="14.5" FontWeight="SemiBold" />
                            <TextBlock Text="{loc:Loc privacy.browserCookies.description}" Style="{StaticResource MutedText}"
                                       TextWrapping="Wrap" Margin="0,4,0,0" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="{loc:Loc privacy.browserCookies.refresh}"
                                Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" VerticalAlignment="Top"
                                Command="{Binding LoadCookiesCommand}" />
                    </Grid>

                    <!-- Suchleiste: filtert live nach Domain oder Cookie-Name -->
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <TextBox x:Name="CookieSearchInput" Style="{StaticResource WhitelistInputStyle}"
                                     Text="{Binding CookieSearch, UpdateSourceTrigger=PropertyChanged, Delay=150}" />
                            <!-- Platzhalter, solange nichts eingegeben ist (wie bei der Whitelist) -->
                            <TextBlock Text="{loc:Loc privacy.browserCookies.searchHint}" IsHitTestVisible="False"
                                       Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=CookieSearchInput}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <TextBlock Grid.Column="1" Text="{Binding CookieCountText}"
                                   Style="{StaticResource MutedText}" VerticalAlignment="Center"
                                   Margin="10,0,0,0" />
                    </Grid>

                    <!-- Hinweis, wenn eine Cookie-DB gesperrt war (laufender Browser) -->
                    <TextBlock Text="{Binding CookieHint}" Style="{StaticResource MutedText}"
                               TextWrapping="Wrap" Margin="0,12,0,0"
                               Visibility="{Binding HasCookieHint, Converter={StaticResource BoolToVis}}" />

                    <!-- Leerzustand -->
                    <TextBlock Text="{Binding CookieEmptyText}" Style="{StaticResource MutedText}"
                               TextWrapping="Wrap" Margin="0,12,0,0"
                               Visibility="{Binding BrowserCookies.Count, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />

                    <!-- Inventar-Liste -->
                    <!-- BubbleWheel: am Listenende geht das Mausrad an die Seite weiter -->
                    <ListBox ItemsSource="{Binding BrowserCookies}" MaxHeight="240" Margin="0,12,0,0"
                             ctl:NestedScrollBehavior.BubbleWheel="True"
                             Background="Transparent" BorderThickness="0"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             VirtualizingStackPanel.IsVirtualizing="True"
                             VirtualizingStackPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,1" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Domain}" FontSize="13" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding Domain}" />
                                        <TextBlock Text="{Binding Detail}" Style="{StaticResource MutedText}"
                                                   FontSize="11" Margin="0,1,0,0" TextTrimming="CharacterEllipsis" />
                                        <!-- Cookie-Namen (Klartext in der Browser-DB) -->
                                        <TextBlock Text="{Binding NamesPreview}" Style="{StaticResource MutedText}"
                                                   FontSize="10.5" Margin="0,1,0,0" Opacity="0.75"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding NamesPreview}"
                                                   Visibility="{Binding HasNames, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>
                                    <!-- Entweder „+"-Button (falls hinzufügbar) oder „Auf Whitelist"-Marker -->
                                    <Button Grid.Column="1" Content="+" Style="{StaticResource SecondaryButton}"
                                            Padding="12,6" VerticalAlignment="Center"
                                            ToolTip="{loc:Loc privacy.browserCookies.add}"
                                            IsEnabled="{Binding CanAdd}"
                                            Visibility="{Binding CanAdd, Converter={StaticResource BoolToVis}}"
                                            Command="{Binding DataContext.AddCookieToWhitelistCommand,
                                                      RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}" />
                                    <TextBlock Grid.Column="1" Text="{loc:Loc privacy.browserCookies.onWhitelist}"
                                               Style="{StaticResource MutedText}" VerticalAlignment="Center"
                                               Visibility="{Binding IsWhitelisted, Converter={StaticResource BoolToVis}}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- ===== Kategorien ===== -->
            <!-- Auswahl-Werkzeuge über der Kategorie-Liste -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="0,18,8,10">
                <Button Content="{loc:Loc common.selectAll}" Style="{StaticResource SecondaryButton}"
                        Padding="12,6" FontSize="12.5"
                        Command="{Binding SelectAllCommand}" />
                <Button Content="{loc:Loc common.deselectAll}" Style="{StaticResource SecondaryButton}"
                        Padding="12,6" FontSize="12.5" Margin="10,0,0,0"
                        Command="{Binding DeselectAllCommand}" />
            </StackPanel>

            <!-- Kein eigener ScrollViewer mehr: die Kategorien scrollen mit der Seite. -->
                <ItemsControl ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Expander Margin="0,0,0,12" IsExpanded="False">
                                <Expander.Header>
                                    <Grid VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <!-- Kategorie in die Analyse einbeziehen -->
                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                  VerticalAlignment="Center" Margin="0,0,14,0"
                                                  ToolTip="{loc:Loc common.includeInAnalysis}" />
                                        <Grid Grid.Column="1" VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <!-- Icon-Chip (Schild) -->
                                            <Border Grid.Column="0" Width="42" Height="42" CornerRadius="12"
                                                    Background="{DynamicResource AccentSoftBrush}"
                                                    VerticalAlignment="Center" Margin="0,0,14,0">
                                                <Path Width="20" Height="20" Stretch="Uniform"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Fill="{DynamicResource AccentBrush}"
                                                      Data="M12 2 L20 5 V11 C20 16 16.5 20.3 12 22 C7.5 20.3 4 16 4 11 V5 Z M12 4.2 L6 6.4 V11 C6 15 8.6 18.5 12 19.9 C15.4 18.5 18 15 18 11 V6.4 Z" />
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding HeaderDisplay}" FontSize="14.5" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Description}" Style="{StaticResource MutedText}"
                                                           FontSize="11.5" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>
                                        <!-- master select-all -->
                                        <CheckBox Grid.Column="2" IsChecked="{Binding AllSelected, Mode=TwoWay}"
                                                  IsThreeState="True" Content="{loc:Loc common.all}" VerticalAlignment="Center"
                                                  Margin="12,0,6,0" />
                                    </Grid>
                                </Expander.Header>

                                <!-- Preview rows -->
                                <Grid Margin="14,0,14,12">
                                    <TextBlock Text="{loc:Loc privacy.emptyPreview}"
                                               Style="{StaticResource MutedText}" Margin="34,10,0,10"
                                               Visibility="{Binding Items.Count, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                                    <Border Background="{DynamicResource BgDeepBrush}" CornerRadius="8"
                                            Visibility="{Binding Items.Count, Converter={StaticResource BoolToVis}}">
                                        <ListBox ItemsSource="{Binding Items}" MaxHeight="320"
                                                 ctl:NestedScrollBehavior.BubbleWheel="True"
                                                 Background="Transparent" BorderThickness="0" Padding="6"
                                                 HorizontalContentAlignment="Stretch"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 ScrollViewer.CanContentScroll="True"
                                                 VirtualizingStackPanel.IsVirtualizing="True"
                                                 VirtualizingStackPanel.VirtualizationMode="Recycling">
                                            <ListBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <VirtualizingStackPanel />
                                                </ItemsPanelTemplate>
                                            </ListBox.ItemsPanel>
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Padding" Value="0" />
                                                    <Setter Property="Margin" Value="0,1" />
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                <Border x:Name="row" Background="{TemplateBinding Background}"
                                                                        CornerRadius="6" Padding="10,7">
                                                                    <ContentPresenter />
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="row" Property="Background"
                                                                                Value="{DynamicResource SurfaceHoverBrush}" />
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                  VerticalAlignment="Center" Margin="0,0,12,0" />
                                                        <!-- Name (fett) + Detail (gedimmt) -->
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontSize="13" FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       ToolTip="{Binding Name}" />
                                                            <TextBlock Text="{Binding Detail}"
                                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                                       FontSize="11" Margin="0,1,0,0"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       ToolTip="{Binding Detail}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Border>
                                </Grid>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

        </StackPanel>
        </ScrollViewer>

        <!-- ===== Status bar ===== -->
        <Border Grid.Row="2" Background="{DynamicResource BgDeepBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Margin="-32,14,-32,0" Padding="32,12">
            <StackPanel>
                <ProgressBar Style="{StaticResource LoadingBar}" Margin="0,0,0,8"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                <TextBlock Text="{Binding StatusText}" Style="{StaticResource MutedText}"
                           FontSize="12.5" VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
