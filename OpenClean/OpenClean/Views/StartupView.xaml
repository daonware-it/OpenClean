<UserControl x:Class="OpenClean.Views.StartupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:OpenClean.Views"
             xmlns:loc="clr-namespace:OpenClean.Services.Localization"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900"
             Background="{DynamicResource BgBrush}"
             FontFamily="{StaticResource AppFont}">
    <UserControl.Resources>
        <local:EnumToBoolConverter x:Key="EnumToBool" />

        <!-- Segment-Button (verbundene Pills) für den Statusfilter -->
        <Style x:Key="SegmentButton" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{TemplateBinding Tag}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="32,10,32,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <Grid Grid.Row="0">
            <!-- Titel und Button-Leiste nebeneinander, der Untertitel darunter über die volle
                 Breite – so bleibt er auch bei vielen Buttons vollständig lesbar. -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Loc startup.title}"
                       Style="{StaticResource HeaderText}" FontSize="24"
                       VerticalAlignment="Center" Margin="0,0,16,0" />
            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                       Text="{loc:Loc startup.subtitle}" TextWrapping="Wrap"
                       Style="{StaticResource MutedText}" Margin="0,4,0,0" />

            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal"
                        HorizontalAlignment="Right" VerticalAlignment="Center">
                <!-- Segmentierter Statusfilter -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <RadioButton Style="{StaticResource SegmentButton}" GroupName="StatusFilter"
                                 Content="{loc:Loc startup.filter.all}" Tag="8,0,0,8"
                                 IsChecked="{Binding StatusFilter, Mode=TwoWay,
                                             Converter={StaticResource EnumToBool}, ConverterParameter=Alle}" />
                    <RadioButton Style="{StaticResource SegmentButton}" GroupName="StatusFilter"
                                 Content="{loc:Loc startup.filter.enabled}" Tag="0" Margin="-1,0,0,0"
                                 IsChecked="{Binding StatusFilter, Mode=TwoWay,
                                             Converter={StaticResource EnumToBool}, ConverterParameter=Aktiviert}" />
                    <RadioButton Style="{StaticResource SegmentButton}" GroupName="StatusFilter"
                                 Content="{loc:Loc startup.filter.disabled}" Tag="0,8,8,0" Margin="-1,0,0,0"
                                 IsChecked="{Binding StatusFilter, Mode=TwoWay,
                                             Converter={StaticResource EnumToBool}, ConverterParameter=Deaktiviert}" />
                </StackPanel>
                <!-- Automatische Staffelung / alle Verzögerungen aufheben -->
                <Button Style="{StaticResource SecondaryButton}" VerticalAlignment="Center" Margin="0,0,8,0"
                        Command="{Binding StaggerCommand}" ToolTip="{loc:Loc startup.stagger.tooltip}">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"
                              Fill="{x:Null}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Data="M12 2 a10 10 0 1 0 10 10 M12 6 v6 l4 2" />
                        <TextBlock Text="{loc:Loc startup.stagger.button}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SecondaryButton}" VerticalAlignment="Center" Margin="0,0,8,0"
                        Command="{Binding ClearDelaysCommand}"
                        Content="{loc:Loc startup.stagger.clear}"
                        Visibility="{Binding HasDelays, Converter={StaticResource BoolToVis}}" />
                <Button Style="{StaticResource SecondaryButton}" VerticalAlignment="Center"
                        Command="{Binding RefreshCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"
                              Fill="{x:Null}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Data="M23 4 v6 h-6 M1 20 v-6 h6 M3.51 9 a9 9 0 0 1 14.85 -3.36 L23 10 M1 17 l4.64 4.36 A9 9 0 0 0 20.49 15" />
                        <TextBlock Text="{loc:Loc common.refresh}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ===== Column header ===== -->
        <Border Grid.Row="1" Margin="0,22,0,0" Padding="18,10" CornerRadius="8,8,0,0"
                Background="{DynamicResource BgDeepBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="70" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{loc:Loc startup.col.program}" Style="{StaticResource MutedText}"
                           FontSize="10.5" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="{loc:Loc startup.col.publisher}" Style="{StaticResource MutedText}"
                           FontSize="10.5" FontWeight="SemiBold" />
                <TextBlock Grid.Column="2" Text="{loc:Loc startup.col.origin}" Style="{StaticResource MutedText}"
                           FontSize="10.5" FontWeight="SemiBold" />
                <TextBlock Grid.Column="3" Text="{loc:Loc startup.col.impact}" Style="{StaticResource MutedText}"
                           FontSize="10.5" FontWeight="SemiBold" />
                <TextBlock Grid.Column="4" Text="{loc:Loc startup.col.delay}" Style="{StaticResource MutedText}"
                           FontSize="10.5" FontWeight="SemiBold" />
                <TextBlock Grid.Column="5" Text="{loc:Loc startup.col.status}" Style="{StaticResource MutedText}"
                           FontSize="10.5" FontWeight="SemiBold" HorizontalAlignment="Right" />
            </Grid>
        </Border>

        <!-- ===== List ===== -->
        <Border Grid.Row="2" Style="{StaticResource Card}" CornerRadius="0,0,10,10"
                BorderThickness="1,0,1,1">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="6,4">
                <ItemsControl ItemsSource="{Binding EntriesView}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="row" Background="Transparent" CornerRadius="8"
                                    Padding="12,12" Margin="0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition Width="70" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Echtes Programm-Icon, sonst farbiger Buchstaben-Avatar -->
                                    <Grid Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid Grid.Column="0" Width="34" Height="34" Margin="0,0,12,0" VerticalAlignment="Center">
                                            <Border CornerRadius="8" Background="{Binding InitialBrush}"
                                                    Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                                                <TextBlock Text="{Binding Initial}" Foreground="White" FontWeight="Bold"
                                                           FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <Image Source="{Binding Icon}" Width="30" Height="30"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}}" />
                                        </Grid>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Command}" Style="{StaticResource MutedText}"
                                                       FontSize="11.5" Margin="0,3,0,0"
                                                       TextTrimming="CharacterEllipsis" ToolTip="{Binding Command}" />
                                        </StackPanel>
                                    </Grid>

                                    <!-- Publisher -->
                                    <TextBlock Grid.Column="1" Text="{Binding PublisherDisplay}"
                                               VerticalAlignment="Center" FontSize="12.5"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextTrimming="CharacterEllipsis" ToolTip="{Binding PublisherDisplay}"
                                               Margin="0,0,12,0" />

                                    <!-- Location -->
                                    <TextBlock Grid.Column="2" Text="{Binding LocationDisplay}"
                                               VerticalAlignment="Center" FontSize="12.5"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextWrapping="Wrap" Margin="0,0,12,0" />

                                    <!-- Impact pill -->
                                    <Border Grid.Column="3" HorizontalAlignment="Left" VerticalAlignment="Center"
                                            CornerRadius="11" Padding="12,5"
                                            Background="{Binding Impact, Converter={StaticResource ImpactToBrush}, ConverterParameter=bg}">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                                     Fill="{Binding Impact, Converter={StaticResource ImpactToBrush}}" />
                                            <TextBlock Text="{Binding ImpactDisplay}" Margin="8,0,0,0"
                                                       FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                                       Foreground="{Binding Impact, Converter={StaticResource ImpactToBrush}}" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Verzögerung: startet das Programm erst x nach der Anmeldung -->
                                    <ComboBox Grid.Column="4"
                                              Height="32" Width="112" HorizontalAlignment="Left" VerticalAlignment="Center"
                                              Margin="0,0,12,0" FontSize="12.5"
                                              ToolTipService.ShowOnDisabled="True"
                                              SelectedValuePath="Seconds"
                                              ItemsSource="{Binding DataContext.DelayOptions,
                                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                              SelectedValue="{Binding DelaySeconds, Mode=TwoWay}"
                                              IsEnabled="{Binding CanDelay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Display}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                        <ComboBox.Style>
                                            <Style TargetType="ComboBox" BasedOn="{StaticResource LanguageCombo}">
                                                <Setter Property="ToolTip" Value="{loc:Loc startup.delay.tooltip}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CanDelay}" Value="False">
                                                        <Setter Property="ToolTip"
                                                                Value="{loc:Loc startup.delay.notSupported}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ComboBox.Style>
                                    </ComboBox>

                                    <!-- Toggle -->
                                    <StackPanel Grid.Column="5" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <ToggleButton IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                      IsEnabled="{Binding CanToggle}"
                                                      ToolTip="{Binding StatusDisplay}" HorizontalAlignment="Right">
                                            <ToggleButton.Style>
                                                <Style TargetType="ToggleButton" BasedOn="{StaticResource ToggleSwitch}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CanToggle}" Value="False">
                                                            <Setter Property="ToolTip"
                                                                    Value="{loc:Loc startup.policyTooltip}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ToggleButton.Style>
                                        </ToggleButton>
                                        <TextBlock Text="{Binding StatusDisplay}" Style="{StaticResource MutedText}"
                                                   FontSize="10.5" HorizontalAlignment="Right" Margin="0,4,2,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True" SourceName="row">
                                    <Setter TargetName="row" Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
                                </Trigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ===== Status bar ===== -->
        <Border Grid.Row="3" Background="{DynamicResource BgDeepBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Margin="-32,14,-32,0" Padding="32,12">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusText}" Style="{StaticResource MutedText}"
                               FontSize="12.5" />
                    <TextBlock Text="{loc:Loc startup.taskSchedulerNote}"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="10.5" Opacity="0.75" Margin="0,3,0,0" />
                    <TextBlock Text="{loc:Loc startup.delay.note}"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="10.5" Opacity="0.75" Margin="0,2,0,0" />
                </StackPanel>
                <ProgressBar Style="{StaticResource LoadingBar}" Width="160" HorizontalAlignment="Right"
                             VerticalAlignment="Center"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
