<Window x:Class="OpenClean.Views.ActivationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="clr-namespace:OpenClean.Services.Localization"
        mc:Ignorable="d"
        Title="{loc:Loc premium.activate.title}"
        Width="480" SizeToContent="Height"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="Transparent" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        FontFamily="{DynamicResource AppFont}">

    <Border CornerRadius="12" Margin="18"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="6" Direction="270"
                              Opacity="0.55" Color="#FF000000" />
        </Border.Effect>
        <Grid Margin="26,24,26,22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header: Icon + Titel (verschiebbar) -->
            <StackPanel Grid.Row="0" Orientation="Horizontal"
                        MouseLeftButtonDown="OnHeaderMouseDown">
                <Border Width="42" Height="42" CornerRadius="10"
                        Background="{DynamicResource BgRaisedBrush}" VerticalAlignment="Center">
                    <!-- Schlüssel-Icon -->
                    <Path Width="20" Height="20" Stretch="Uniform" VerticalAlignment="Center"
                          HorizontalAlignment="Center"
                          Fill="{DynamicResource AccentBrush}"
                          Data="M7 14 A5 5 0 1 1 12 9 L21 9 L21 12 L18 12 L18 15 L15 15 L15 12 L12 12 A5 5 0 0 1 7 14 Z M7 11.5 A1.5 1.5 0 1 0 7 8.5 A1.5 1.5 0 0 0 7 11.5 Z" />
                </Border>
                <TextBlock Text="{loc:Loc premium.activate.title}" VerticalAlignment="Center" Margin="14,0,0,0"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}" />
            </StackPanel>

            <!-- Hinweis -->
            <TextBlock Grid.Row="1" Margin="0,16,0,0"
                       Text="{loc:Loc premium.activate.hint}"
                       FontSize="13" TextWrapping="Wrap" LineHeight="20"
                       Foreground="{DynamicResource TextMutedBrush}" />

            <!-- Schlüssel-Eingabe -->
            <TextBox Grid.Row="2" Margin="0,14,0,0" Padding="12,10"
                     FontSize="14" FontWeight="SemiBold"
                     CharacterCasing="Upper"
                     Text="{Binding LicenseKeyInput, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding IsNotBusy}" />

            <!-- Status -->
            <TextBlock Grid.Row="3" Margin="0,10,0,0"
                       Text="{Binding StatusText}"
                       FontSize="12.5" TextWrapping="Wrap"
                       Foreground="{DynamicResource AccentBrush}" />

            <!-- Datenschutz-Hinweis -->
            <TextBlock Grid.Row="4" Margin="0,12,0,0"
                       Text="{loc:Loc premium.activate.privacy}"
                       FontSize="11" TextWrapping="Wrap" Opacity="0.75"
                       Foreground="{DynamicResource TextMutedBrush}" />

            <!-- Buttons -->
            <Grid Grid.Row="5" Margin="0,22,0,0">
                <Button Content="{loc:Loc premium.action.buy}" Style="{StaticResource SecondaryButton}"
                        HorizontalAlignment="Left" Command="{Binding BuyCommand}" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{loc:Loc confirm.cancel}" Style="{StaticResource SecondaryButton}"
                            IsCancel="True" Click="OnCancel" />
                    <Button Content="{loc:Loc premium.activate.action}" Style="{StaticResource PrimaryButton}"
                            IsDefault="True" Command="{Binding ActivateCommand}" Margin="12,0,0,0" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
