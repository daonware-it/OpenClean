<UserControl x:Class="OpenClean.Views.UninstallView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:OpenClean.Views"
             xmlns:loc="clr-namespace:OpenClean.Services.Localization"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="920"
             Background="{DynamicResource BgBrush}"
             FontFamily="{StaticResource AppFont}">
    <UserControl.Resources>
        <local:EnumToBoolConverter x:Key="EnumToBool" />

        <!-- Suchfeld -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Height" Value="38" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                CornerRadius="10" Padding="12,0">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Segment-Button (Sortierung) -->
        <Style x:Key="SegmentButton" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                CornerRadius="{TemplateBinding Tag}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="32,10,32,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <Grid Grid.Row="0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{loc:Loc uninstall.title}" Style="{StaticResource HeaderText}" FontSize="24" />
                <TextBlock Text="{loc:Loc uninstall.subtitle}" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <!-- Suche -->
                <Grid Width="210" VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBox x:Name="SearchBox" Style="{StaticResource SearchBoxStyle}"
                             Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="{loc:Loc uninstall.searchPlaceholder}" IsHitTestVisible="False"
                               Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
                <!-- Sortierung -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <RadioButton Style="{StaticResource SegmentButton}" GroupName="Sort" Tag="8,0,0,8"
                                 Content="{loc:Loc uninstall.sort.size}"
                                 IsChecked="{Binding Sort, Mode=TwoWay, Converter={StaticResource EnumToBool}, ConverterParameter=Groesse}" />
                    <RadioButton Style="{StaticResource SegmentButton}" GroupName="Sort" Tag="0,8,8,0" Margin="-1,0,0,0"
                                 Content="{loc:Loc uninstall.sort.name}"
                                 IsChecked="{Binding Sort, Mode=TwoWay, Converter={StaticResource EnumToBool}, ConverterParameter=Name}" />
                </StackPanel>
                <Button Content="{loc:Loc common.refresh}" Style="{StaticResource SecondaryButton}"
                        VerticalAlignment="Center" Command="{Binding RefreshCommand}" />
                <Button Content="{loc:Loc uninstall.action.uninstallSelected}" Style="{StaticResource PrimaryButton}"
                        VerticalAlignment="Center" Margin="12,0,0,0"
                        Command="{Binding UninstallSelectedCommand}" />
            </StackPanel>
        </Grid>

        <!-- ===== Reste-Banner (sichtbar nach Deinstallation) ===== -->
        <Border Grid.Row="1" Margin="0,18,0,0" Padding="20,16" CornerRadius="10"
                Background="{DynamicResource BgRaisedBrush}"
                BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1.5"
                Visibility="{Binding HasLeftovers, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding LeftoverHeading}" FontSize="15" FontWeight="SemiBold" />
                        <TextBlock Text="{loc:Loc uninstall.leftover.hint}" Style="{StaticResource MutedText}"
                                   FontSize="12" Margin="0,3,0,0" TextWrapping="Wrap" MaxWidth="620"
                                   HorizontalAlignment="Left" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="{loc:Loc uninstall.leftover.ignore}" Style="{StaticResource SecondaryButton}"
                                Padding="14,8" Command="{Binding IgnoreLeftoversCommand}" />
                        <Button Content="{loc:Loc uninstall.leftover.action}" Style="{StaticResource PrimaryButton}"
                                Padding="16,8" Margin="10,0,0,0" Command="{Binding RemoveLeftoversCommand}" />
                    </StackPanel>
                </Grid>
                <Border Background="{DynamicResource BgDeepBrush}" CornerRadius="8" Margin="0,14,0,0">
                    <ListBox ItemsSource="{Binding Leftovers}" MaxHeight="200"
                             Background="Transparent" BorderThickness="0" Padding="6"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingStackPanel.IsVirtualizing="True"
                             VirtualizingStackPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Padding" Value="8,5" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              VerticalAlignment="Center" />
                                    <!-- Typ-Kennzeichen -->
                                    <Border Grid.Column="1" CornerRadius="5" Padding="7,2" Margin="12,0,12,0"
                                            VerticalAlignment="Center" Background="{DynamicResource SurfaceBrush}">
                                        <TextBlock FontSize="10.5" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextMutedBrush}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{loc:Loc uninstall.leftover.folder}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRegistry}" Value="True">
                                                            <Setter Property="Text" Value="{loc:Loc uninstall.leftover.registry}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="{Binding Path}" VerticalAlignment="Center"
                                               FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                               TextTrimming="CharacterEllipsis" ToolTip="{Binding Path}" />
                                    <TextBlock Grid.Column="3" Text="{Binding SizeDisplay}" VerticalAlignment="Center"
                                               FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                               Margin="12,0,4,0" MinWidth="64" TextAlignment="Right" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </StackPanel>
        </Border>

        <!-- ===== Spaltenkopf ===== -->
        <Border Grid.Row="2" Margin="0,18,0,0" Padding="18,10" CornerRadius="8,8,0,0"
                Background="{DynamicResource BgDeepBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="130" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="1" Text="{loc:Loc uninstall.col.program}" Style="{StaticResource MutedText}"
                           FontSize="10.5" FontWeight="SemiBold" />
                <TextBlock Grid.Column="2" Text="{loc:Loc uninstall.col.version}" Style="{StaticResource MutedText}"
                           FontSize="10.5" FontWeight="SemiBold" />
                <TextBlock Grid.Column="3" Text="{loc:Loc uninstall.col.size}" Style="{StaticResource MutedText}"
                           FontSize="10.5" FontWeight="SemiBold" />
                <TextBlock Grid.Column="4" Text="{loc:Loc uninstall.col.action}" Style="{StaticResource MutedText}"
                           FontSize="10.5" FontWeight="SemiBold" HorizontalAlignment="Right" />
            </Grid>
        </Border>

        <!-- ===== Liste ===== -->
        <Border Grid.Row="3" Style="{StaticResource Card}" CornerRadius="0,0,10,10" BorderThickness="1,0,1,1">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="6,4">
                <ItemsControl ItemsSource="{Binding AppsView}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="row" Background="Transparent" CornerRadius="8" Padding="12,11" Margin="0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="130" />
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              IsEnabled="{Binding CanUninstall}" VerticalAlignment="Center" />

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding Name}" />
                                        <TextBlock Text="{Binding PublisherDisplay}" Style="{StaticResource MutedText}"
                                                   FontSize="11.5" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding InstallDateDisplay}" />
                                    </StackPanel>

                                    <TextBlock Grid.Column="2" Text="{Binding Version}" VerticalAlignment="Center"
                                               FontSize="12.5" Foreground="{DynamicResource TextMutedBrush}"
                                               TextTrimming="CharacterEllipsis" Margin="0,0,12,0" />

                                    <TextBlock Grid.Column="3" Text="{Binding SizeDisplay}" VerticalAlignment="Center"
                                               FontSize="12.5" FontWeight="SemiBold"
                                               TextAlignment="Left" Margin="0,0,12,0" />

                                    <Button Grid.Column="4" HorizontalAlignment="Right" VerticalAlignment="Center"
                                            Content="{loc:Loc uninstall.action.uninstall}"
                                            IsEnabled="{Binding CanUninstall}"
                                            Command="{Binding UninstallCommand}"
                                            Style="{StaticResource SecondaryButton}" Padding="14,7" FontSize="12.5" />
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True" SourceName="row">
                                    <Setter TargetName="row" Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
                                </Trigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ===== Statusleiste ===== -->
        <Border Grid.Row="4" Background="{DynamicResource BgDeepBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Margin="-32,14,-32,0" Padding="32,12">
            <StackPanel>
                <!-- Fortschritt der Batch-Deinstallation -->
                <ProgressBar Minimum="0" Maximum="100" Value="{Binding ProgressPercent, Mode=OneWay}"
                             Height="6" Margin="0,0,0,8"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                <Grid>
                    <TextBlock Text="{Binding StatusText}" Style="{StaticResource MutedText}"
                               FontSize="12.5" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding SelectionSummary}" Style="{StaticResource MutedText}"
                               FontSize="12.5" FontWeight="SemiBold" HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource AccentBrush}" />
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
