<Window x:Class="OpenClean.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Bereinigung bestätigen"
        Width="440" SizeToContent="Height"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="Transparent" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        FontFamily="{DynamicResource AppFont}">

    <Border CornerRadius="12" Margin="18"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="6" Direction="270"
                              Opacity="0.55" Color="#FF000000" />
        </Border.Effect>
        <Grid Margin="26,24,26,22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header: Icon + Titel (verschiebbar) -->
            <StackPanel Grid.Row="0" Orientation="Horizontal"
                        MouseLeftButtonDown="OnHeaderMouseDown">
                <Border Width="42" Height="42" CornerRadius="10"
                        Background="{DynamicResource BgRaisedBrush}" VerticalAlignment="Center">
                    <!-- Papierkorb-/Warn-Icon -->
                    <Path Width="20" Height="20" Stretch="Uniform" VerticalAlignment="Center"
                          HorizontalAlignment="Center"
                          Fill="{DynamicResource DangerBrush}"
                          Data="M9 2 L15 2 L16 4 L21 4 L21 6 L3 6 L3 4 L8 4 Z M5 7 L19 7 L18 22 L6 22 Z" />
                </Border>
                <TextBlock Text="Bereinigung bestätigen" VerticalAlignment="Center" Margin="14,0,0,0"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}" />
            </StackPanel>

            <!-- Nachricht -->
            <TextBlock x:Name="MessageText" Grid.Row="1" Margin="0,18,0,0"
                       FontSize="14" TextWrapping="Wrap" LineHeight="21"
                       Foreground="{DynamicResource TextMutedBrush}" />

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="0,24,0,0">
                <Button Content="Abbrechen" Style="{StaticResource SecondaryButton}"
                        IsCancel="True" Click="OnCancel" />
                <Button Content="Bereinigen" Style="{StaticResource PrimaryButton}"
                        IsDefault="True" Click="OnConfirm" Margin="12,0,0,0" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
