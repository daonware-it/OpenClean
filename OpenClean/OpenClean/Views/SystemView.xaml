<UserControl x:Class="OpenClean.Views.SystemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:OpenClean.Converters"
             xmlns:loc="clr-namespace:OpenClean.Services.Localization"
             mc:Ignorable="d"
             d:DesignHeight="760" d:DesignWidth="900"
             Background="{DynamicResource BgBrush}"
             FontFamily="{StaticResource AppFont}">
    <UserControl.Resources>
        <conv:PercentToStarConverter x:Key="PctStar" />

        <Style x:Key="TileCaption" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- Balkenfarbe je Warnstufe eines Laufwerks -->
        <Style x:Key="DriveBarStyle" TargetType="Rectangle">
            <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding WarningLevel}" Value="Low">
                    <Setter Property="Fill" Value="{DynamicResource WarnBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding WarningLevel}" Value="Critical">
                    <Setter Property="Fill" Value="{DynamicResource DangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Warn-Badge (nur sichtbar bei Warnung) -->
        <Style x:Key="WarnBadgeStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Background" Value="{DynamicResource WarnBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasWarning}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding WarningLevel}" Value="Critical">
                    <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="32,10,32,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <Grid Grid.Row="0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{loc:Loc system.title}" Style="{StaticResource HeaderText}" FontSize="24" />
                <TextBlock Text="{loc:Loc system.subtitle}"
                           Style="{StaticResource MutedText}" Margin="0,4,0,0" />
            </StackPanel>
            <Button Content="{loc:Loc common.refresh}" Style="{StaticResource SecondaryButton}"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Command="{Binding RefreshCommand}" />
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,22,-12,0" Padding="0,0,12,24">
            <StackPanel>

                <!-- ===== RAM (Info-only) ===== -->
                <Border Style="{StaticResource Card}" Padding="24">
                    <StackPanel>
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="{loc:Loc system.ramHeading}" Style="{StaticResource TileCaption}" />
                                <TextBlock Text="{Binding RamSummary}" Style="{StaticResource MutedText}"
                                           FontSize="13" Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="{Binding RamPercentDisplay}" FontSize="34" FontWeight="Bold"
                                           VerticalAlignment="Center" />
                                <Button Content="{loc:Loc common.refresh}" Style="{StaticResource SecondaryButton}"
                                        Padding="12,7" FontSize="12" VerticalAlignment="Center" Margin="16,0,0,0"
                                        Command="{Binding RefreshRamCommand}" />
                            </StackPanel>
                        </Grid>

                        <!-- Bar -->
                        <Border Height="14" CornerRadius="7" Background="{DynamicResource BgDeepBrush}"
                                Margin="0,18,0,0" ClipToBounds="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{Binding RamPercent, Converter={StaticResource PctStar}}" />
                                    <ColumnDefinition Width="{Binding RamFreePercent, Converter={StaticResource PctStar}}" />
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0" Fill="{DynamicResource AccentBrush}" RadiusX="7" RadiusY="7" />
                            </Grid>
                        </Border>

                        <Grid Margin="0,12,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{loc:Loc system.used}" Style="{StaticResource MutedText}" FontSize="12" />
                                <TextBlock Text="{Binding UsedRam}" FontSize="12" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="{loc:Loc system.free}" Style="{StaticResource MutedText}" FontSize="12" />
                                <TextBlock Text="{Binding AvailableRam}" FontSize="12" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="{loc:Loc system.total}" Style="{StaticResource MutedText}" FontSize="12" />
                                <TextBlock Text="{Binding TotalRam}" FontSize="12" FontWeight="SemiBold" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ===== Drives ===== -->
                <TextBlock Text="{loc:Loc system.drives}" Style="{StaticResource HeaderText}" FontSize="16" Margin="2,22,0,0" />
                <TextBlock Text="{Binding DrivesSummary}" Style="{StaticResource MutedText}" Margin="2,4,0,0" />

                <ItemsControl ItemsSource="{Binding Drives}" Margin="0,12,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}" Padding="20" Margin="0,0,0,12">
                                <StackPanel>
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding TitleDisplay}" FontSize="16" FontWeight="SemiBold" />
                                            <!-- Warn-Badge -->
                                            <Border Style="{StaticResource WarnBadgeStyle}" CornerRadius="9"
                                                    Padding="10,3" Margin="12,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding WarningText}" Foreground="#FF10261F"
                                                           FontSize="11.5" FontWeight="SemiBold" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding PercentDisplay}" HorizontalAlignment="Right"
                                                   FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
                                    </Grid>

                                    <!-- Usage bar -->
                                    <Border Height="12" CornerRadius="6" Background="{DynamicResource BgDeepBrush}"
                                            Margin="0,14,0,0" ClipToBounds="True">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="{Binding UsedPercent, Converter={StaticResource PctStar}}" />
                                                <ColumnDefinition Width="{Binding FreePercent, Converter={StaticResource PctStar}}" />
                                            </Grid.ColumnDefinitions>
                                            <Rectangle Grid.Column="0" Style="{StaticResource DriveBarStyle}" RadiusX="6" RadiusY="6" />
                                        </Grid>
                                    </Border>

                                    <TextBlock Text="{Binding SummaryDisplay}" Style="{StaticResource MutedText}"
                                               FontSize="12.5" Margin="0,10,0,0" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
