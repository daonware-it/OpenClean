<UserControl x:Class="OpenClean.Views.SystemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:OpenClean.Converters"
             xmlns:controls="clr-namespace:OpenClean.Controls"
             xmlns:loc="clr-namespace:OpenClean.Services.Localization"
             mc:Ignorable="d"
             d:DesignHeight="760" d:DesignWidth="900"
             Background="{DynamicResource BgBrush}"
             FontFamily="{StaticResource AppFont}">
    <UserControl.Resources>
        <conv:PercentToStarConverter x:Key="PctStar" />

        <Style x:Key="TileCaption" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- Balkenfarbe je Warnstufe eines Laufwerks -->
        <Style x:Key="DriveBarStyle" TargetType="Rectangle">
            <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding WarningLevel}" Value="Low">
                    <Setter Property="Fill" Value="{DynamicResource WarnBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding WarningLevel}" Value="Critical">
                    <Setter Property="Fill" Value="{DynamicResource DangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Ringfarbe je Warnstufe (Laufwerks-Ring) -->
        <Style x:Key="DriveRingStyle" TargetType="controls:ScoreRing">
            <Setter Property="Thickness" Value="5" />
            <Setter Property="TrackBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="RingBrush" Value="{DynamicResource AccentBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding WarningLevel}" Value="Low">
                    <Setter Property="RingBrush" Value="{DynamicResource WarnBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding WarningLevel}" Value="Critical">
                    <Setter Property="RingBrush" Value="{DynamicResource DangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Prozentfarbe je Warnstufe (rechts) -->
        <Style x:Key="DrivePercentStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding WarningLevel}" Value="Low">
                    <Setter Property="Foreground" Value="{DynamicResource WarnBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding WarningLevel}" Value="Critical">
                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Warn-Badge (nur sichtbar bei Warnung) -->
        <Style x:Key="WarnBadgeStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Background" Value="{DynamicResource WarnBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasWarning}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding WarningLevel}" Value="Critical">
                    <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Ampel-Punkt je Gesundheitsstufe. Gleiche Trigger-Tabelle wie DriveBarStyle:
             DataTrigger auf das Enum statt eines eigenen Konverters. -->
        <Style x:Key="HealthDotStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="10" />
            <Setter Property="Height" Value="10" />
            <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Info.Health}" Value="Warning">
                    <Setter Property="Fill" Value="{DynamicResource WarnBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Info.Health}" Value="Failing">
                    <Setter Property="Fill" Value="{DynamicResource DangerBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Info.Health}" Value="Unknown">
                    <Setter Property="Fill" Value="{DynamicResource TextMutedBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HealthTextStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Info.Health}" Value="Warning">
                    <Setter Property="Foreground" Value="{DynamicResource WarnBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Info.Health}" Value="Failing">
                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Info.Health}" Value="Unknown">
                    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Ein Detailwert im Pro-Bereich: Beschriftung oben, Zahl in MonoFont darunter. -->
        <Style x:Key="HealthMetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Margin" Value="0,2,0,0" />
            <!-- Ohne explizite Foreground fiele der Wert auf WPF-Schwarz zurück und wäre im
                 Dark-Mode unlesbar. Die zentrale, theme-fähige TextBrush sorgt in beiden Themes
                 für vollen Kontrast (Dark hell, Light dunkel). -->
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="32,10,32,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <Grid Grid.Row="0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{loc:Loc system.title}" Style="{StaticResource HeaderText}" FontSize="24" />
                <TextBlock Text="{loc:Loc system.subtitle}"
                           Style="{StaticResource MutedText}" Margin="0,4,0,0" />
            </StackPanel>
            <Button Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" VerticalAlignment="Center"
                    Command="{Binding RefreshCommand}">
                <StackPanel Orientation="Horizontal">
                    <Path Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"
                          Fill="{x:Null}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                          Data="M23 4 v6 h-6 M1 20 v-6 h6 M3.51 9 a9 9 0 0 1 14.85 -3.36 L23 10 M1 17 l4.64 4.36 A9 9 0 0 0 20.49 15" />
                    <TextBlock Text="{loc:Loc common.refresh}" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,22,-12,0" Padding="0,0,12,24">
            <StackPanel>

                <!-- ===== RAM (Info-only) ===== -->
                <Border Style="{StaticResource Card}" Padding="24" ClipToBounds="True">
                    <Grid>
                    <Rectangle Margin="-24" Fill="{DynamicResource HeroGlowBrush}" IsHitTestVisible="False" />
                    <StackPanel>
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Icon-Chip (Speicher) -->
                                <Border Width="46" Height="46" CornerRadius="13" Background="{DynamicResource AccentSoftBrush}"
                                        VerticalAlignment="Center" Margin="0,0,14,0">
                                    <Path Width="24" Height="24" Stretch="Uniform" HorizontalAlignment="Center"
                                          VerticalAlignment="Center" Fill="{DynamicResource AccentBrush}"
                                          Data="M6 6 H18 V18 H6 Z M9 3 H10 V6 H9 Z M14 3 H15 V6 H14 Z M9 18 H10 V21 H9 Z M14 18 H15 V21 H14 Z M3 9 H6 V10 H3 Z M3 14 H6 V15 H3 Z M18 9 H21 V10 H18 Z M18 14 H21 V15 H18 Z" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{loc:Loc system.ramHeading}" Style="{StaticResource TileCaption}" />
                                    <TextBlock Text="{Binding RamSummary}" Style="{StaticResource MutedText}"
                                               FontSize="13" FontFamily="{StaticResource MonoFont}" Margin="0,4,0,0" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="{Binding RamPercentDisplay}" FontSize="38" FontWeight="Bold"
                                           FontFamily="{StaticResource MonoFont}" Foreground="{DynamicResource AccentBrush}"
                                           HorizontalAlignment="Right" />
                                <TextBlock Text="{loc:Loc system.ramLoad}" Style="{StaticResource MutedText}"
                                           FontSize="11.5" HorizontalAlignment="Right" Margin="0,2,0,0" />
                            </StackPanel>
                        </Grid>

                        <!-- Live-Wellenform der RAM-Auslastung (reine Anzeige) -->
                        <Border Height="96" CornerRadius="10" Background="{DynamicResource BgDeepBrush}"
                                Margin="0,18,0,0" ClipToBounds="True">
                            <controls:RamWaveform Level="{Binding RamPercent}" />
                        </Border>

                        <Border Margin="0,16,0,0" Padding="0,14,0,0"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                            <Grid>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Rectangle Width="9" Height="9" RadiusX="2" RadiusY="2"
                                               Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="{loc:Loc system.used}" Style="{StaticResource MutedText}" FontSize="12.5" />
                                    <TextBlock Text="{Binding UsedRam}" Style="{StaticResource MetricText}" FontSize="12.5" FontWeight="SemiBold" Margin="4,0,0,0" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{loc:Loc system.free}" Style="{StaticResource MutedText}" FontSize="12.5" />
                                    <TextBlock Text="{Binding AvailableRam}" Style="{StaticResource MetricText}" FontSize="12.5" FontWeight="SemiBold" Margin="4,0,0,0" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock Text="{loc:Loc system.total}" Style="{StaticResource MutedText}" FontSize="12.5" />
                                    <TextBlock Text="{Binding TotalRam}" Style="{StaticResource MetricText}" FontSize="12.5" FontWeight="SemiBold" Margin="4,0,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                    </Grid>
                </Border>

                <!-- ===== Drives ===== -->
                <TextBlock Text="{loc:Loc system.drives}" Style="{StaticResource HeaderText}" FontSize="16" Margin="2,22,0,0" />
                <TextBlock Text="{Binding DrivesSummary}" Style="{StaticResource MutedText}" Margin="2,4,0,0" />

                <ItemsControl ItemsSource="{Binding Drives}" Margin="0,12,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}" Padding="18" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Ring mit Prozentzahl -->
                                    <Grid Grid.Column="0" Width="58" Height="58" Margin="0,0,18,0" VerticalAlignment="Center">
                                        <controls:ScoreRing Score="{Binding UsedPercent}" Style="{StaticResource DriveRingStyle}" />
                                        <TextBlock Text="{Binding UsedPercent, StringFormat={}{0:0}}"
                                                   FontFamily="{StaticResource MonoFont}" FontSize="14" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Grid>

                                    <!-- Name + Detailzeile -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding TitleDisplay}" FontSize="15" FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />
                                            <Border Style="{StaticResource WarnBadgeStyle}" CornerRadius="9"
                                                    Padding="10,3" Margin="12,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding WarningText}" Foreground="#FF10261F"
                                                           FontSize="11.5" FontWeight="SemiBold" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding SummaryDisplay}" Style="{StaticResource MutedText}"
                                                   FontSize="12.5" FontFamily="{StaticResource MonoFont}" Margin="0,3,0,0" />
                                    </StackPanel>

                                    <!-- Prozent rechts -->
                                    <TextBlock Grid.Column="2" Text="{Binding PercentDisplay}"
                                               Style="{StaticResource DrivePercentStyle}" FontSize="18" FontWeight="Bold"
                                               FontFamily="{StaticResource MonoFont}" VerticalAlignment="Center" Margin="16,0,4,0" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ===== Belegungsanalyse (Sunburst) ===== -->
                <TextBlock Text="{loc:Loc storage.heading}" Style="{StaticResource HeaderText}"
                           FontSize="16" Margin="2,22,0,0" />
                <TextBlock Text="{loc:Loc storage.subtitle}" Style="{StaticResource MutedText}"
                           Margin="2,4,0,0" />

                <Border Style="{StaticResource Card}" Padding="22" Margin="0,12,0,0"
                        DataContext="{Binding DataContext.StorageAnalysis,
                                      RelativeSource={RelativeSource AncestorType=Window}}">
                    <StackPanel>

                        <!-- Kopfzeile: Laufwerk + Analysieren/Abbrechen -->
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{loc:Loc storage.selectDrive}" Style="{StaticResource MutedText}"
                                           VerticalAlignment="Center" Margin="0,0,10,0" />
                                <!-- ItemTemplate statt DisplayMemberPath: Nur so übernimmt der
                                     gestylte geschlossene Zustand (SelectionBoxItemTemplate) den
                                     Anzeigetext korrekt, sonst erscheint dort der Klassenname. -->
                                <ComboBox ItemsSource="{Binding Drives}" SelectedItem="{Binding SelectedDrive}"
                                          MinWidth="180" VerticalAlignment="Center">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding TitleDisplay}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Content="{loc:Loc storage.cancel}" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding CancelCommand}"
                                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                                <Button Content="{loc:Loc storage.analyze}" Style="{StaticResource PrimaryButton}"
                                        Command="{Binding ScanCommand}" Margin="12,0,0,0" />
                            </StackPanel>
                        </Grid>

                        <!-- Fortschritt -->
                        <StackPanel Margin="0,16,0,0"
                                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding ScanProgressText}" Style="{StaticResource MutedText}"
                                       FontSize="12" TextTrimming="CharacterEllipsis" />
                            <ProgressBar Minimum="0" Maximum="100" Height="6" Margin="0,6,0,0"
                                         Value="{Binding ScanProgressPercent, Mode=OneWay}" />
                        </StackPanel>

                        <!-- Leerzustand -->
                        <TextBlock Text="{Binding StatusText}" Style="{StaticResource MutedText}"
                                   Margin="0,18,0,0" HorizontalAlignment="Center"
                                   Visibility="{Binding HasResult, Converter={StaticResource BoolToVis},
                                                ConverterParameter=invert}" />

                        <!-- Diagramm + Seitenleiste -->
                        <Grid Margin="0,18,0,0"
                              Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <controls:SunburstChart Grid.Column="0" Width="360" Height="360"
                                                    Root="{Binding CurrentNode}"
                                                    DrillDownCommand="{Binding DrillDownCommand}"
                                                    NavigateUpCommand="{Binding NavigateUpCommand}"
                                                    TrackBrush="{DynamicResource TextMutedBrush}"
                                                    OtherBrush="{DynamicResource WarnBrush}"
                                                    StrokeBrush="{DynamicResource SurfaceBrush}"
                                                    CenterTextBrush="{DynamicResource TextBrush}" />

                            <StackPanel Grid.Column="1" Margin="24,4,0,0">
                                <!-- Breadcrumb: jeder Knoten ist anklickbar -->
                                <ItemsControl ItemsSource="{Binding Breadcrumb}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="{Binding Name}" Padding="6,2" FontSize="12.5"
                                                        Background="Transparent" BorderThickness="0"
                                                        Foreground="{DynamicResource AccentBrush}" Cursor="Hand"
                                                        Command="{Binding DataContext.NavigateToCommand,
                                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}" />
                                                <TextBlock Text="›" Style="{StaticResource MutedText}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="{loc:Loc storage.topFolders}" Style="{StaticResource HeaderText}"
                                           FontSize="13" Margin="6,16,0,0" />

                                <ItemsControl ItemsSource="{Binding TopFolders}" Margin="0,8,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Background="Transparent" BorderThickness="0" Padding="6,7"
                                                    HorizontalContentAlignment="Stretch" Cursor="Hand"
                                                    Command="{Binding DataContext.NavigateToCommand,
                                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <Grid>
                                                    <TextBlock Text="{Binding Name}" FontSize="13"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding FullPath}" />
                                                    <TextBlock Text="{Binding TotalBytes, Converter={StaticResource Bytes}}"
                                                               HorizontalAlignment="Right" FontSize="12.5"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               Foreground="{DynamicResource TextMutedBrush}" />
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="{loc:Loc storage.back}" Style="{StaticResource MutedText}"
                                           FontSize="11.5" Margin="6,16,0,0" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ==================== Datenträger-Gesundheit ==================== -->
                <!-- 22px Abstand nach oben trennt die Karte konsistent von der Analyse-Karte
                     darüber (gleiche Sektions-Distanz wie bei den übrigen Abschnitten). -->
                <Border Style="{StaticResource Card}" Margin="0,22,0,12" Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc system.health.title}" Style="{StaticResource HeaderText}" />
                        <TextBlock Text="{loc:Loc system.health.subtitle}" Style="{StaticResource MutedText}"
                                   TextWrapping="Wrap" Margin="0,4,0,0" />

                        <ProgressBar Style="{StaticResource LoadingBar}" Margin="0,12,0,0"
                                     Visibility="{Binding IsDiskHealthLoading,
                                                  Converter={StaticResource BoolToVis}}" />
                        <TextBlock Text="{loc:Loc system.health.loading}" Style="{StaticResource MutedText}"
                                   Margin="0,6,0,0"
                                   Visibility="{Binding IsDiskHealthLoading,
                                                Converter={StaticResource BoolToVis}}" />

                        <TextBlock Text="{loc:Loc system.health.empty}" Style="{StaticResource MutedText}"
                                   Margin="0,12,0,0"
                                   Visibility="{Binding HasNoDiskHealth, Converter={StaticResource BoolToVis}}" />

                        <ItemsControl ItemsSource="{Binding DiskHealth}" Margin="0,12,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource BgBrush}" CornerRadius="10"
                                            Padding="14,12" Margin="0,0,0,8">
                                        <StackPanel>
                                            <!-- Kopfzeile: Ampel + Modell links, Kapazität rechts -->
                                            <Grid>
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Style="{StaticResource HealthDotStyle}"
                                                             VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding Info.Model}" FontSize="13.5"
                                                               FontWeight="SemiBold" Margin="10,0,0,0"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" />

                                                    <!-- SSD/HDD-Badge -->
                                                    <Border CornerRadius="6" Padding="7,1" Margin="10,0,0,0"
                                                            VerticalAlignment="Center"
                                                            Background="{DynamicResource SurfaceBrush}"
                                                            Visibility="{Binding Info.HasMediaType,
                                                                         Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="{Binding Info.MediaTypeText}"
                                                                   FontSize="10.5" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                                    </Border>

                                                    <TextBlock Text="{Binding Info.LettersDisplay}"
                                                               Style="{StaticResource MutedText}"
                                                               FontSize="11.5" Margin="10,0,0,0"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding Info.HasLetters,
                                                                            Converter={StaticResource BoolToVis}}" />
                                                </StackPanel>

                                                <TextBlock Text="{Binding Info.CapacityDisplay}"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           FontFamily="{StaticResource MonoFont}" FontSize="12.5"
                                                           Foreground="{DynamicResource TextMutedBrush}" />
                                            </Grid>

                                            <!-- Klartext der Ampel: das EINZIGE Urteil in der freien Fassung -->
                                            <TextBlock Text="{Binding Info.HealthText}"
                                                       Style="{StaticResource HealthTextStyle}"
                                                       Margin="20,6,0,0" />

                                            <!-- Aufklappen -->
                                            <Button Command="{Binding ToggleCommand}" Cursor="Hand"
                                                    HorizontalAlignment="Left" Margin="20,8,0,0"
                                                    Background="Transparent" BorderThickness="0" Padding="0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{loc:Loc system.health.details}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource InfoBrush}" />
                                                    <!-- Schloss ohne Pro-Berechtigung (Muster: MainWindow.xaml) -->
                                                    <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets"
                                                               FontSize="10.5" Margin="6,0,0,0"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextMutedBrush}"
                                                               Visibility="{Binding IsDetailLocked,
                                                                            Converter={StaticResource BoolToVis}}" />
                                                </StackPanel>
                                            </Button>

                                            <!-- Detailbereich -->
                                            <StackPanel Margin="20,10,0,0"
                                                        Visibility="{Binding IsExpanded,
                                                                     Converter={StaticResource BoolToVis}}">
                                                <!-- Ohne Pro: Upsell statt Werte -->
                                                <TextBlock Text="{loc:Loc system.health.detailsLocked}"
                                                           Style="{StaticResource MutedText}" TextWrapping="Wrap"
                                                           Visibility="{Binding IsDetailLocked,
                                                                        Converter={StaticResource BoolToVis}}" />

                                                <!-- Mit Pro, aber ohne Werte: ehrlicher Hinweis -->
                                                <TextBlock Text="{Binding DetailsUnavailableText}"
                                                           TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock"
                                                               BasedOn="{StaticResource MutedText}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding IsDetailLocked}"
                                                                                   Value="False" />
                                                                        <Condition Binding="{Binding HasDetails}"
                                                                                   Value="False" />
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <!-- Mit Pro und Werten: die Einzelwerte -->
                                                <WrapPanel Visibility="{Binding HasDetails,
                                                                       Converter={StaticResource BoolToVis}}">
                                                    <StackPanel Margin="0,0,28,10" MinWidth="120">
                                                        <TextBlock Text="{loc:Loc system.health.temp}"
                                                                   Style="{StaticResource TileCaption}" />
                                                        <TextBlock Text="{Binding Details.TemperatureCelsius,
                                                                          StringFormat={}{0} °C, TargetNullValue=—}"
                                                                   Style="{StaticResource HealthMetricValueStyle}" />
                                                    </StackPanel>
                                                    <StackPanel Margin="0,0,28,10" MinWidth="120">
                                                        <TextBlock Text="{loc:Loc system.health.wear}"
                                                                   Style="{StaticResource TileCaption}" />
                                                        <TextBlock Text="{Binding Details.WearRemainingPercent,
                                                                          StringFormat={}{0} %, TargetNullValue=—}"
                                                                   Style="{StaticResource HealthMetricValueStyle}" />
                                                    </StackPanel>
                                                    <StackPanel Margin="0,0,28,10" MinWidth="120">
                                                        <TextBlock Text="{loc:Loc system.health.poweronhours}"
                                                                   Style="{StaticResource TileCaption}" />
                                                        <TextBlock Text="{Binding Details.PowerOnHours,
                                                                          TargetNullValue=—}"
                                                                   Style="{StaticResource HealthMetricValueStyle}" />
                                                    </StackPanel>
                                                    <StackPanel Margin="0,0,28,10" MinWidth="120">
                                                        <TextBlock Text="{loc:Loc system.health.powercycles}"
                                                                   Style="{StaticResource TileCaption}" />
                                                        <TextBlock Text="{Binding Details.PowerCycles,
                                                                          TargetNullValue=—}"
                                                                   Style="{StaticResource HealthMetricValueStyle}" />
                                                    </StackPanel>
                                                    <StackPanel Margin="0,0,28,10" MinWidth="120">
                                                        <TextBlock Text="{loc:Loc system.health.reallocated}"
                                                                   Style="{StaticResource TileCaption}" />
                                                        <TextBlock Text="{Binding Details.ReallocatedSectors,
                                                                          TargetNullValue=—}"
                                                                   Style="{StaticResource HealthMetricValueStyle}" />
                                                    </StackPanel>
                                                    <StackPanel Margin="0,0,28,10" MinWidth="120">
                                                        <TextBlock Text="{loc:Loc system.health.pending}"
                                                                   Style="{StaticResource TileCaption}" />
                                                        <TextBlock Text="{Binding Details.PendingSectors,
                                                                          TargetNullValue=—}"
                                                                   Style="{StaticResource HealthMetricValueStyle}" />
                                                    </StackPanel>
                                                    <StackPanel Margin="0,0,28,10" MinWidth="120">
                                                        <TextBlock Text="{loc:Loc system.health.tbw}"
                                                                   Style="{StaticResource TileCaption}" />
                                                        <TextBlock Text="{Binding TotalWrittenDisplay}"
                                                                   Style="{StaticResource HealthMetricValueStyle}" />
                                                    </StackPanel>
                                                </WrapPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
