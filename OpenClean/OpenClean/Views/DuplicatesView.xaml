<UserControl x:Class="OpenClean.Views.DuplicatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="clr-namespace:OpenClean.Services.Localization"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="980"
             Background="{DynamicResource BgBrush}"
             FontFamily="{StaticResource AppFont}">

    <Grid Margin="32,10,32,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                <TextBlock Text="{loc:Loc duplicates.title}" Style="{StaticResource HeaderText}" FontSize="24" />
                <TextBlock Text="{loc:Loc duplicates.subtitle}" Style="{StaticResource MutedText}" Margin="0,4,0,0"
                           TextTrimming="CharacterEllipsis" ToolTip="{loc:Loc duplicates.subtitle}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="{loc:Loc duplicates.action.addFolder}" Style="{StaticResource SecondaryButton}"
                        Command="{Binding AddFolderCommand}" />
                <Button Content="{loc:Loc duplicates.action.cancel}" Style="{StaticResource SecondaryButton}"
                        Margin="12,0,0,0" Command="{Binding CancelCommand}"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                <Button Content="{loc:Loc duplicates.action.scan}" Style="{StaticResource PrimaryButton}"
                        Margin="12,0,0,0" Command="{Binding ScanCommand}" />
            </StackPanel>
        </Grid>

        <!-- ===== Ordnerauswahl (Chips) ===== -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,18,0,0" Padding="18,14">
            <StackPanel>
                <TextBlock Text="{loc:Loc duplicates.folders.heading}" Style="{StaticResource MutedText}"
                           FontSize="11.5" FontWeight="SemiBold" />
                <TextBlock Text="{loc:Loc duplicates.folders.empty}" Style="{StaticResource MutedText}"
                           FontSize="12.5" Margin="0,10,0,2"
                           Visibility="{Binding HasFolders, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                <ItemsControl ItemsSource="{Binding Folders}" Margin="0,10,0,0"
                              Visibility="{Binding HasFolders, Converter={StaticResource BoolToVis}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="8" Padding="12,6" Margin="0,0,8,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding}" FontSize="12.5" VerticalAlignment="Center"
                                               MaxWidth="360" TextTrimming="CharacterEllipsis" ToolTip="{Binding}" />
                                    <Button Content="✕" FontSize="11" Margin="10,0,0,0" Padding="4,0"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                                            Foreground="{DynamicResource TextMutedBrush}"
                                            ToolTip="{loc:Loc duplicates.action.removeFolder}"
                                            Command="{Binding DataContext.RemoveFolderCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- ===== Auswahl-Werkzeuge ===== -->
        <Grid Grid.Row="2" Margin="0,14,0,0"
              Visibility="{Binding HasGroups, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{loc:Loc duplicates.autoselect.label}" Style="{StaticResource MutedText}"
                           FontSize="12.5" VerticalAlignment="Center" Margin="2,0,10,0" />
                <Button Content="{loc:Loc duplicates.autoselect.keepNewest}" Style="{StaticResource SecondaryButton}"
                        Padding="12,6" FontSize="12" Command="{Binding AutoSelectCommand}" CommandParameter="Newest" />
                <Button Content="{loc:Loc duplicates.autoselect.keepOldest}" Style="{StaticResource SecondaryButton}"
                        Padding="12,6" FontSize="12" Margin="8,0,0,0"
                        Command="{Binding AutoSelectCommand}" CommandParameter="Oldest" />
                <Button Content="{loc:Loc duplicates.autoselect.keepShortestPath}" Style="{StaticResource SecondaryButton}"
                        Padding="12,6" FontSize="12" Margin="8,0,0,0"
                        Command="{Binding AutoSelectCommand}" CommandParameter="Smallest" />
                <Button Content="{loc:Loc duplicates.autoselect.clear}" Style="{StaticResource SecondaryButton}"
                        Padding="12,6" FontSize="12" Margin="8,0,0,0"
                        Command="{Binding ClearSelectionCommand}" />
            </StackPanel>
            <Button Grid.Column="1" Content="{loc:Loc duplicates.action.delete}" Style="{StaticResource PrimaryButton}"
                    Padding="16,8" Command="{Binding DeleteSelectedCommand}" />
        </Grid>

        <!-- ===== Gruppen (links) + Vergleich nebeneinander (rechts) ===== -->
        <Grid Grid.Row="3" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Gruppenliste -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{loc:Loc duplicates.groups.heading}"
                               Style="{StaticResource MutedText}" FontSize="11.5" FontWeight="SemiBold"
                               Margin="10,8,10,6" />
                    <ListBox Grid.Row="1" ItemsSource="{Binding Groups}"
                             SelectedItem="{Binding SelectedGroup, Mode=TwoWay}"
                             Background="Transparent" BorderThickness="0"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingStackPanel.IsVirtualizing="True"
                             VirtualizingStackPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Padding" Value="10,8" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="bd" Background="Transparent" CornerRadius="8"
                                                    Padding="{TemplateBinding Padding}" Margin="2,1">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background"
                                                            Value="{DynamicResource SurfaceHoverBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="bd" Property="Background"
                                                            Value="{DynamicResource AccentSoftBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding Name}" />
                                        <TextBlock Text="{Binding Summary}" Style="{StaticResource MutedText}"
                                                   FontSize="11.5" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <Border Grid.Column="1" CornerRadius="6" Padding="7,2" VerticalAlignment="Center"
                                            Background="{DynamicResource SurfaceBrush}">
                                        <TextBlock FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AccentBrush}">
                                            <Run Text="{Binding SelectedCount, Mode=OneWay}" /><Run Text=" ✓" />
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Vergleichsansicht: Kopien nebeneinander -->
            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="16">
                <Grid>
                    <TextBlock Text="{loc:Loc duplicates.compare.empty}" Style="{StaticResource MutedText}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap"
                               MaxWidth="360" TextAlignment="Center"
                               Visibility="{Binding HasSelectedGroup, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                    <Grid Visibility="{Binding HasSelectedGroup, Converter={StaticResource BoolToVis}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="{loc:Loc duplicates.compare.heading}"
                                   Style="{StaticResource MutedText}" FontSize="11.5" FontWeight="SemiBold"
                                   Margin="2,0,0,10" />
                        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding SelectedGroup.Files}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="280" Margin="0,0,14,4" Padding="14"
                                                CornerRadius="10" VerticalAlignment="Top"
                                                Background="{DynamicResource BgDeepBrush}"
                                                BorderThickness="1.5">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <!-- Bild-Vorschau (nur bei Bilddateien) -->
                                                <Border Height="140" CornerRadius="8" Margin="0,0,0,12"
                                                        Background="{DynamicResource SurfaceBrush}"
                                                        Visibility="{Binding HasPreview, Converter={StaticResource BoolToVis}}">
                                                    <Image Source="{Binding PreviewSource}" Stretch="Uniform" Margin="6" />
                                                </Border>
                                                <TextBlock Text="{Binding FileName}" FontSize="13.5" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" ToolTip="{Binding FilePath}" />
                                                <TextBlock Text="{Binding Directory}" Style="{StaticResource MutedText}"
                                                           FontSize="11.5" Margin="0,4,0,10"
                                                           TextTrimming="CharacterEllipsis" ToolTip="{Binding Directory}" />
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Loc duplicates.file.size}"
                                                               Style="{StaticResource MutedText}" FontSize="11.5" Margin="0,0,12,3" />
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SizeDisplay}"
                                                               FontSize="11.5" FontWeight="SemiBold" />
                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{loc:Loc duplicates.file.modified}"
                                                               Style="{StaticResource MutedText}" FontSize="11.5" Margin="0,0,12,3" />
                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ModifiedDisplay}"
                                                               FontSize="11.5" />
                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{loc:Loc duplicates.file.created}"
                                                               Style="{StaticResource MutedText}" FontSize="11.5" Margin="0,0,12,0" />
                                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CreatedDisplay}"
                                                               FontSize="11.5" />
                                                </Grid>
                                                <CheckBox Content="{loc:Loc duplicates.file.deleteThis}" Margin="0,12,0,0"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== Statusleiste ===== -->
        <Border Grid.Row="4" Background="{DynamicResource BgDeepBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Margin="-32,14,-32,0" Padding="32,12">
            <StackPanel>
                <ProgressBar IsIndeterminate="True" Height="6" Margin="0,0,0,8"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding StatusText}" Style="{StaticResource MutedText}"
                               FontSize="12.5" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" Margin="0,0,16,0" />
                    <TextBlock Grid.Column="1" Text="{Binding SelectionSummary}" Style="{StaticResource MutedText}"
                               FontSize="12.5" FontWeight="SemiBold" HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource AccentBrush}" />
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
