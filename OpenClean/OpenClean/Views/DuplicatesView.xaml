<UserControl x:Class="OpenClean.Views.DuplicatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="clr-namespace:OpenClean.Services.Localization"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="980"
             Background="{DynamicResource BgBrush}"
             FontFamily="{StaticResource AppFont}">

    <Grid Margin="32,10,32,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                <TextBlock Text="{loc:Loc duplicates.title}" Style="{StaticResource HeaderText}" FontSize="24" />
                <TextBlock Text="{loc:Loc duplicates.subtitle}" Style="{StaticResource MutedText}" Margin="0,4,0,0"
                           TextTrimming="CharacterEllipsis" ToolTip="{loc:Loc duplicates.subtitle}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Style="{StaticResource SecondaryButton}" Command="{Binding AddFolderCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M2 4 L8 4 L10 6 L20 6 L20 18 L2 18 Z M10 9 H12 V11 H14 V13 H12 V15 H10 V13 H8 V11 H10 Z" />
                        <TextBlock Text="{loc:Loc duplicates.action.addFolder}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SecondaryButton}"
                        Margin="12,0,0,0" Command="{Binding CancelCommand}"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"
                              Fill="{x:Null}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Data="M4 4 L20 20 M20 4 L4 20" />
                        <TextBlock Text="{loc:Loc duplicates.action.cancel}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource PrimaryButton}"
                        Margin="12,0,0,0" Command="{Binding ScanCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"
                              Fill="{x:Null}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Data="M11 5 a6 6 0 1 0 0 12 a6 6 0 1 0 0 -12 Z M20.5 20.5 L15.8 15.8" />
                        <TextBlock Text="{loc:Loc duplicates.action.scan}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ===== Ordnerauswahl (Chips) + Modus + Ähnlichkeitsschwelle ===== -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,18,0,0" Padding="18,14">
            <StackPanel>
                <!-- Modus-Umschaltung: exakt (kostenlos) vs. ähnlich (Pro) -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" CornerRadius="8" Padding="12,10" Background="{DynamicResource BgDeepBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <RadioButton GroupName="ScanMode" VerticalContentAlignment="Center"
                                     IsChecked="{Binding IsExactMode, Mode=TwoWay}">
                            <StackPanel Margin="6,0,0,0">
                                <TextBlock Text="{loc:Loc duplicates.mode.exact}" FontSize="13" FontWeight="SemiBold" />
                                <TextBlock Text="{loc:Loc duplicates.mode.exactHint}" Style="{StaticResource MutedText}"
                                           FontSize="11.5" Margin="0,3,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                        </RadioButton>
                    </Border>
                    <Border Grid.Column="2" CornerRadius="8" Padding="12,10" Background="{DynamicResource BgDeepBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <RadioButton GroupName="ScanMode" VerticalContentAlignment="Center"
                                     IsChecked="{Binding IsSimilarMode, Mode=TwoWay}">
                            <StackPanel Margin="6,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{loc:Loc duplicates.mode.similar}" FontSize="13" FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                    <Border Margin="8,0,0,0" Padding="6,1" CornerRadius="5" VerticalAlignment="Center"
                                            Background="{DynamicResource AccentSoftBrush}"
                                            Visibility="{Binding IsSimilarLocked, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="PRO" FontSize="9.5" FontWeight="Bold"
                                                   Foreground="{DynamicResource AccentBrush}" />
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{loc:Loc duplicates.mode.similarHint}" Style="{StaticResource MutedText}"
                                           FontSize="11.5" Margin="0,3,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                        </RadioButton>
                    </Border>
                </Grid>

                <TextBlock Text="{loc:Loc duplicates.folders.heading}" Style="{StaticResource MutedText}"
                           FontSize="11.5" FontWeight="SemiBold" />
                <TextBlock Text="{loc:Loc duplicates.folders.empty}" Style="{StaticResource MutedText}"
                           FontSize="12.5" Margin="0,10,0,2"
                           Visibility="{Binding HasFolders, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                <ItemsControl ItemsSource="{Binding Folders}" Margin="0,10,0,0"
                              Visibility="{Binding HasFolders, Converter={StaticResource BoolToVis}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="8" Padding="12,6" Margin="0,0,8,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding}" FontSize="12.5" VerticalAlignment="Center"
                                               MaxWidth="360" TextTrimming="CharacterEllipsis" ToolTip="{Binding}" />
                                    <Button Content="✕" FontSize="11" Margin="10,0,0,0" Padding="4,0"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                                            Foreground="{DynamicResource TextMutedBrush}"
                                            ToolTip="{loc:Loc duplicates.action.removeFolder}"
                                            Command="{Binding DataContext.RemoveFolderCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Ähnlichkeitsschwelle (nur im Ähnlich-Modus; deaktiviert wenn gesperrt) -->
                <StackPanel Margin="0,14,0,0"
                            Visibility="{Binding IsSimilarMode, Converter={StaticResource BoolToVis}}"
                            IsEnabled="{Binding IsSimilarUnlocked}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{loc:Loc duplicates.similar.threshold}"
                                   Style="{StaticResource MutedText}" FontSize="12.5" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="0,0,12,0" />
                        <Slider Grid.Column="1" Minimum="50" Maximum="100" VerticalAlignment="Center"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                Value="{Binding SimilarityThreshold, Mode=TwoWay}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="12,0,0,0"
                                   FontSize="12.5" FontWeight="SemiBold" MinWidth="42" TextAlignment="Right"
                                   Foreground="{DynamicResource AccentBrush}">
                            <Run Text="{Binding SimilarityThreshold, Mode=OneWay}" /><Run Text=" %" />
                        </TextBlock>
                    </Grid>
                    <TextBlock Text="{loc:Loc duplicates.similar.thresholdHint}" Style="{StaticResource MutedText}"
                               FontSize="11.5" Margin="0,6,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ===== Auswahl-Werkzeuge ===== -->
        <Grid Grid.Row="2" Margin="0,14,0,0"
              Visibility="{Binding HasGroups, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{loc:Loc duplicates.autoselect.label}" Style="{StaticResource MutedText}"
                           FontSize="12.5" VerticalAlignment="Center" Margin="2,0,10,0" />
                <Button Content="{loc:Loc duplicates.autoselect.keepNewest}" Style="{StaticResource SecondaryButton}"
                        Padding="12,6" FontSize="12" Command="{Binding AutoSelectCommand}" CommandParameter="Newest" />
                <Button Content="{loc:Loc duplicates.autoselect.keepOldest}" Style="{StaticResource SecondaryButton}"
                        Padding="12,6" FontSize="12" Margin="8,0,0,0"
                        Command="{Binding AutoSelectCommand}" CommandParameter="Oldest" />
                <Button Content="{loc:Loc duplicates.autoselect.keepShortestPath}" Style="{StaticResource SecondaryButton}"
                        Padding="12,6" FontSize="12" Margin="8,0,0,0"
                        Command="{Binding AutoSelectCommand}" CommandParameter="Smallest" />
                <Button Content="{loc:Loc duplicates.autoselect.clear}" Style="{StaticResource SecondaryButton}"
                        Padding="12,6" FontSize="12" Margin="8,0,0,0"
                        Command="{Binding ClearSelectionCommand}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Sicheres Löschen (Pro): mehrfaches Überschreiben, unwiderruflich -->
                <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox VerticalAlignment="Center"
                                  IsChecked="{Binding UseSecureDelete, Mode=TwoWay}"
                                  Content="{loc:Loc duplicates.secureDelete.option}" />
                        <Border Margin="8,0,0,0" Padding="6,1" CornerRadius="5" VerticalAlignment="Center"
                                Background="{DynamicResource AccentSoftBrush}"
                                Visibility="{Binding IsSecureDeleteLocked, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="PRO" FontSize="9.5" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}" />
                        </Border>
                        <!-- Durchlauf-Auswahl (nur bei aktivem Secure Delete) -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0"
                                    Visibility="{Binding UseSecureDelete, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{loc:Loc duplicates.secureDelete.passes}" Style="{StaticResource MutedText}"
                                       FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <RadioButton GroupName="SecurePasses" Content="1×" Margin="0,0,8,0" VerticalAlignment="Center"
                                         IsChecked="{Binding IsPasses1, Mode=TwoWay}" />
                            <RadioButton GroupName="SecurePasses" Content="3×" Margin="0,0,8,0" VerticalAlignment="Center"
                                         IsChecked="{Binding IsPasses3, Mode=TwoWay}" />
                            <RadioButton GroupName="SecurePasses" Content="7×" VerticalAlignment="Center"
                                         IsChecked="{Binding IsPasses7, Mode=TwoWay}" />
                        </StackPanel>
                    </StackPanel>
                    <!-- Roter Warnhinweis, sichtbar bei aktivem sicheren Löschen -->
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                Visibility="{Binding UseSecureDelete, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="⚠" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"
                                   Foreground="{DynamicResource DangerBrush}" />
                        <TextBlock Text="{loc:Loc duplicates.secureDelete.option}" FontSize="11.5"
                                   TextWrapping="Wrap" MaxWidth="360" VerticalAlignment="Center"
                                   Foreground="{DynamicResource DangerBrush}" />
                    </StackPanel>
                </StackPanel>
                <Button Style="{StaticResource PrimaryButton}" VerticalAlignment="Center"
                        Padding="16,8" Command="{Binding DeleteSelectedCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M6 2 L18 2 L18 6 L6 6 Z M8 6 L16 6 L15 21 L9 21 Z" />
                        <TextBlock Text="{loc:Loc duplicates.action.delete}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ===== Gruppen (links) + Vergleich nebeneinander (rechts) ===== -->
        <Grid Grid.Row="3" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Gruppenliste -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{loc:Loc duplicates.groups.heading}"
                               Style="{StaticResource MutedText}" FontSize="11.5" FontWeight="SemiBold"
                               Margin="10,8,10,6" />
                    <ListBox Grid.Row="1" ItemsSource="{Binding Groups}"
                             SelectedItem="{Binding SelectedGroup, Mode=TwoWay}"
                             Background="Transparent" BorderThickness="0"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingStackPanel.IsVirtualizing="True"
                             VirtualizingStackPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Padding" Value="10,8" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="bd" Background="Transparent" CornerRadius="8"
                                                    Padding="{TemplateBinding Padding}" Margin="2,1">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background"
                                                            Value="{DynamicResource SurfaceHoverBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="bd" Property="Background"
                                                            Value="{DynamicResource AccentSoftBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding Name}" />
                                        <TextBlock Text="{Binding Summary}" Style="{StaticResource MutedText}"
                                                   FontSize="11.5" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <Border Grid.Column="1" CornerRadius="6" Padding="7,2" VerticalAlignment="Center"
                                            Background="{DynamicResource AccentSoftBrush}">
                                        <TextBlock FontSize="11" FontWeight="SemiBold"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   Foreground="{DynamicResource AccentBrush}">
                                            <Run Text="{Binding SelectedCount, Mode=OneWay}" /><Run Text=" ✓" />
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Vergleichsansicht: Kopien nebeneinander -->
            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="16">
                <Grid>
                    <TextBlock Text="{loc:Loc duplicates.compare.empty}" Style="{StaticResource MutedText}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap"
                               MaxWidth="360" TextAlignment="Center"
                               Visibility="{Binding HasSelectedGroup, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                    <Grid Visibility="{Binding HasSelectedGroup, Converter={StaticResource BoolToVis}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="{loc:Loc duplicates.compare.heading}"
                                   Style="{StaticResource MutedText}" FontSize="11.5" FontWeight="SemiBold"
                                   Margin="2,0,0,10" />
                        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding SelectedGroup.Files}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="280" Margin="0,0,14,4" Padding="14"
                                                CornerRadius="10" VerticalAlignment="Top"
                                                Background="{DynamicResource BgDeepBrush}"
                                                BorderThickness="1.5">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <!-- Bild-Vorschau (nur bei Bilddateien) -->
                                                <Border Height="140" CornerRadius="8" Margin="0,0,0,12"
                                                        Background="{DynamicResource SurfaceBrush}"
                                                        Visibility="{Binding HasPreview, Converter={StaticResource BoolToVis}}">
                                                    <Image Source="{Binding PreviewSource}" Stretch="Uniform" Margin="6" />
                                                </Border>
                                                <TextBlock Text="{Binding FileName}" FontSize="13.5" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" ToolTip="{Binding FilePath}" />
                                                <TextBlock Text="{Binding Directory}" Style="{StaticResource MutedText}"
                                                           FontSize="11.5" Margin="0,4,0,10"
                                                           TextTrimming="CharacterEllipsis" ToolTip="{Binding Directory}" />
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Loc duplicates.file.size}"
                                                               Style="{StaticResource MutedText}" FontSize="11.5" Margin="0,0,12,3" />
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SizeDisplay}"
                                                               Style="{StaticResource MetricText}" FontSize="11.5" FontWeight="SemiBold" />
                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{loc:Loc duplicates.file.modified}"
                                                               Style="{StaticResource MutedText}" FontSize="11.5" Margin="0,0,12,3" />
                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ModifiedDisplay}"
                                                               FontSize="11.5" />
                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{loc:Loc duplicates.file.created}"
                                                               Style="{StaticResource MutedText}" FontSize="11.5" Margin="0,0,12,0" />
                                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CreatedDisplay}"
                                                               FontSize="11.5" />
                                                </Grid>
                                                <CheckBox Content="{loc:Loc duplicates.file.deleteThis}" Margin="0,12,0,0"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== Statusleiste ===== -->
        <Border Grid.Row="4" Background="{DynamicResource BgDeepBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Margin="-32,14,-32,0" Padding="32,12">
            <StackPanel>
                <ProgressBar Style="{StaticResource LoadingBar}" Margin="0,0,0,8"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding StatusText}" Style="{StaticResource MutedText}"
                               FontSize="12.5" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" Margin="0,0,16,0" />
                    <TextBlock Grid.Column="1" Text="{Binding SelectionSummary}" Style="{StaticResource MutedText}"
                               FontSize="12.5" FontWeight="SemiBold" HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource AccentBrush}" />
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
