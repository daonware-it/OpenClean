<UserControl x:Class="OpenClean.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:OpenClean.Converters"
             mc:Ignorable="d"
             d:DesignHeight="760" d:DesignWidth="900"
             Background="{DynamicResource BgBrush}"
             FontFamily="{StaticResource AppFont}">
    <UserControl.Resources>
        <conv:PercentToStarConverter x:Key="PctStar" />

        <!-- Kleine Statistik-Kachel-Überschrift -->
        <Style x:Key="TileCaption" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- Score-abhängige Balkenfarbe -->
        <Style x:Key="ScoreBarStyle" TargetType="Rectangle">
            <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ScoreLevel}" Value="Improvable">
                    <Setter Property="Fill" Value="{DynamicResource WarnBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding ScoreLevel}" Value="Critical">
                    <Setter Property="Fill" Value="{DynamicResource DangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ScoreNumberStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ScoreLevel}" Value="Improvable">
                    <Setter Property="Foreground" Value="{DynamicResource WarnBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding ScoreLevel}" Value="Critical">
                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Empfehlungs-Punkt (Severity-Farbe) -->
        <Style x:Key="RecoDotStyle" TargetType="Ellipse">
            <Setter Property="Fill" Value="{DynamicResource TextMutedBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Severity}" Value="Positive">
                    <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="Warning">
                    <Setter Property="Fill" Value="{DynamicResource WarnBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="Critical">
                    <Setter Property="Fill" Value="{DynamicResource DangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="32,28,32,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <Grid Grid.Row="0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Übersicht" Style="{StaticResource HeaderText}" FontSize="24" />
                <TextBlock Text="Ein ehrlicher Blick auf dein System – ausschließlich echte Messwerte."
                           Style="{StaticResource MutedText}" Margin="0,4,0,0" />
            </StackPanel>
            <Button Content="Aktualisieren" Style="{StaticResource SecondaryButton}"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Command="{Binding RefreshCommand}" />
        </Grid>

        <!-- ===== Lade-Banner (deutlich sichtbar, während im Hintergrund analysiert wird) ===== -->
        <Border Grid.Row="1" Margin="0,18,0,0" CornerRadius="10" Padding="20,15"
                Background="{DynamicResource BgRaisedBrush}"
                BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1.5"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <!-- pulsierender Punkt = „läuft im Hintergrund“ -->
                    <Ellipse Width="12" Height="12" Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Ellipse.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="1" To="0.2" Duration="0:0:0.8" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <TextBlock Text="Daten werden im Hintergrund geladen …"
                               FontSize="14.5" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               VerticalAlignment="Center" Margin="13,0,0,0" />
                </StackPanel>

                <!-- animierter Indeterminate-Balken -->
                <ProgressBar Style="{StaticResource LoadingBar}" Margin="0,13,0,0" />

                <TextBlock Text="{Binding StatusText}" Style="{StaticResource MutedText}"
                           FontSize="12" Margin="0,9,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- ===== Scrollable content ===== -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,22,-12,0" Padding="0,0,12,24">
            <StackPanel>
                <!-- Inhalt wird während des Ladens gedimmt, damit das Banner heraussticht -->
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Opacity" Value="1" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                <Setter Property="Opacity" Value="0.5" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <!-- ===== Score card ===== -->
                <Border Style="{StaticResource Card}" Padding="24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Left: number + label + bar -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="GESAMT-SCORE" Style="{StaticResource TileCaption}" />
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="{Binding Score}" Style="{StaticResource ScoreNumberStyle}"
                                           FontSize="64" FontWeight="Bold" />
                                <TextBlock Text="/100" Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="20" VerticalAlignment="Bottom" Margin="6,0,0,14" />
                            </StackPanel>
                            <Border CornerRadius="9" Padding="12,5" HorizontalAlignment="Left" Margin="0,2,0,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ScoreLevel}" Value="Improvable">
                                                <Setter Property="Background" Value="{DynamicResource WarnBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ScoreLevel}" Value="Critical">
                                                <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding ScoreLabel}" Foreground="#FF10261F"
                                           FontWeight="SemiBold" FontSize="13" />
                            </Border>

                            <!-- Score bar -->
                            <Border Height="8" CornerRadius="4" Background="{DynamicResource BgDeepBrush}"
                                    Margin="0,16,0,0" ClipToBounds="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{Binding Score, Converter={StaticResource PctStar}}" />
                                        <ColumnDefinition Width="{Binding Score, Converter={StaticResource PctStar}, ConverterParameter=inv}" />
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0" Style="{StaticResource ScoreBarStyle}" RadiusX="4" RadiusY="4" />
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Right: transparent factor breakdown -->
                        <StackPanel Grid.Column="1" Margin="28,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ScoreExplanation}" Style="{StaticResource MutedText}"
                                       TextWrapping="Wrap" Margin="0,0,0,8" />
                            <ItemsControl ItemsSource="{Binding ScoreFactors}"
                                          Visibility="{Binding HasScoreFactors, Converter={StaticResource BoolToVis}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="46" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding PointsDisplay}"
                                                       Foreground="{DynamicResource DangerBrush}"
                                                       FontWeight="SemiBold" FontSize="13" />
                                            <TextBlock Grid.Column="1" Text="{Binding Description}"
                                                       Foreground="{DynamicResource TextBrush}" FontSize="13"
                                                       TextWrapping="Wrap" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                        Visibility="{Binding HasScoreFactors, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                                <Path Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"
                                      Fill="{DynamicResource AccentBrush}" Data="M 0,5 L 4,9 L 11,0" />
                                <TextBlock Text="100/100 – keine Punktabzüge." Margin="10,0,0,0"
                                           Foreground="{DynamicResource TextBrush}" FontSize="13" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ===== Stat tiles row ===== -->
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- RAM tile -->
                    <Border Grid.Column="0" Style="{StaticResource Card}" Padding="18">
                        <StackPanel>
                            <TextBlock Text="RAM-AUSLASTUNG" Style="{StaticResource TileCaption}" />
                            <TextBlock Text="{Binding RamPercentDisplay}" FontSize="30" FontWeight="Bold"
                                       Margin="0,4,0,0" />
                            <Border Height="6" CornerRadius="3" Background="{DynamicResource BgDeepBrush}"
                                    Margin="0,10,0,0" ClipToBounds="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{Binding RamPercent, Converter={StaticResource PctStar}}" />
                                        <ColumnDefinition Width="{Binding RamFreePercent, Converter={StaticResource PctStar}}" />
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0" Fill="{DynamicResource AccentBrush}" RadiusX="3" RadiusY="3" />
                                </Grid>
                            </Border>
                            <TextBlock Text="{Binding RamSummary}" Style="{StaticResource MutedText}"
                                       FontSize="11.5" Margin="0,10,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- Speicher tile -->
                    <Border Grid.Column="2" Style="{StaticResource Card}" Padding="18">
                        <StackPanel>
                            <TextBlock Text="SPEICHERPLATZ" Style="{StaticResource TileCaption}" />
                            <TextBlock Text="{Binding Drives.Count, StringFormat={}{0} Laufwerk(e)}"
                                       FontSize="24" FontWeight="Bold" Margin="0,4,0,0" />
                            <TextBlock Text="{Binding DrivesSummary}" Style="{StaticResource MutedText}"
                                       FontSize="11.5" Margin="0,8,0,0" TextWrapping="Wrap" />
                            <Button Content="Details ansehen" Style="{StaticResource SecondaryButton}"
                                    Padding="12,7" FontSize="12" HorizontalAlignment="Left" Margin="0,12,0,0"
                                    Command="{Binding OpenSystemCommand}" />
                        </StackPanel>
                    </Border>

                    <!-- Autostart tile -->
                    <Border Grid.Column="4" Style="{StaticResource Card}" Padding="18">
                        <StackPanel>
                            <TextBlock Text="AUTOSTART" Style="{StaticResource TileCaption}" />
                            <TextBlock Text="{Binding StartupEnabled}" FontSize="30" FontWeight="Bold"
                                       Margin="0,4,0,0" />
                            <TextBlock Text="{Binding StartupSummary}" Style="{StaticResource MutedText}"
                                       FontSize="11.5" Margin="0,8,0,0" TextWrapping="Wrap" />
                            <Button Content="Autostart öffnen" Style="{StaticResource SecondaryButton}"
                                    Padding="12,7" FontSize="12" HorizontalAlignment="Left" Margin="0,12,0,0"
                                    Command="{Binding OpenStartupCommand}" />
                        </StackPanel>
                    </Border>

                    <!-- Temp tile -->
                    <Border Grid.Column="6" Style="{StaticResource Card}" Padding="18">
                        <StackPanel>
                            <TextBlock Text="BEREINIGBAR" Style="{StaticResource TileCaption}" />
                            <TextBlock Text="{Binding TempReclaimable}" FontSize="30" FontWeight="Bold"
                                       Margin="0,4,0,0" />
                            <TextBlock Text="{Binding TempSummary}" Style="{StaticResource MutedText}"
                                       FontSize="11.5" Margin="0,8,0,0" TextWrapping="Wrap" />
                            <Button Content="Bereinigen" Style="{StaticResource SecondaryButton}"
                                    Padding="12,7" FontSize="12" HorizontalAlignment="Left" Margin="0,12,0,0"
                                    Command="{Binding OpenCleanerCommand}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ===== Recommendations ===== -->
                <Border Style="{StaticResource Card}" Padding="22" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="Empfehlungen" Style="{StaticResource HeaderText}" FontSize="16" />
                        <ItemsControl ItemsSource="{Binding Recommendations}" Margin="0,10,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource BgRaisedBrush}" CornerRadius="8"
                                            Padding="16,13" Margin="0,5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Ellipse Grid.Column="0" Width="10" Height="10" VerticalAlignment="Top"
                                                     Margin="0,5,14,0" Style="{StaticResource RecoDotStyle}" />

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Text}" Style="{StaticResource MutedText}"
                                                           FontSize="12" Margin="0,3,0,0" TextWrapping="Wrap" />
                                            </StackPanel>

                                            <Button Grid.Column="2" Content="{Binding ActionLabel}"
                                                    Style="{StaticResource PrimaryButton}" Padding="16,8" FontSize="13"
                                                    VerticalAlignment="Center" Margin="14,0,0,0"
                                                    Command="{Binding ActionCommand}"
                                                    Visibility="{Binding HasAction, Converter={StaticResource BoolToVis}}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- ===== Status ===== -->
                <StackPanel Orientation="Horizontal" Margin="2,14,0,0">
                    <ProgressBar Style="{StaticResource LoadingBar}" Width="140" VerticalAlignment="Center"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Text="{Binding StatusText}" Style="{StaticResource MutedText}"
                               FontSize="12" VerticalAlignment="Center" Margin="12,0,0,0" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
