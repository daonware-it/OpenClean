<UserControl x:Class="OpenClean.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:OpenClean.Converters"
             xmlns:controls="clr-namespace:OpenClean.Controls"
             xmlns:loc="clr-namespace:OpenClean.Services.Localization"
             mc:Ignorable="d"
             d:DesignHeight="760" d:DesignWidth="900"
             Background="{DynamicResource BgBrush}"
             FontFamily="{StaticResource AppFont}">
    <UserControl.Resources>
        <conv:PercentToStarConverter x:Key="PctStar" />

        <!-- Kleine Statistik-Kachel-Überschrift -->
        <Style x:Key="TileCaption" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- Score-abhängige Balkenfarbe -->
        <Style x:Key="ScoreBarStyle" TargetType="Rectangle">
            <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ScoreLevel}" Value="Improvable">
                    <Setter Property="Fill" Value="{DynamicResource WarnBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding ScoreLevel}" Value="Critical">
                    <Setter Property="Fill" Value="{DynamicResource DangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ScoreNumberStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ScoreLevel}" Value="Improvable">
                    <Setter Property="Foreground" Value="{DynamicResource WarnBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding ScoreLevel}" Value="Critical">
                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Ringfarbe + farbiger Glow abhängig von der Score-Stufe (wie Zahl/Balken) -->
        <Style x:Key="ScoreRingStyle" TargetType="controls:ScoreRing">
            <Setter Property="RingBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="TrackBrush" Value="{DynamicResource BgDeepBrush}" />
            <Setter Property="Thickness" Value="14" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="22" ShadowDepth="0" Opacity="0.55" Color="#FF34D399" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ScoreLevel}" Value="Improvable">
                    <Setter Property="RingBrush" Value="{DynamicResource WarnBrush}" />
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="22" ShadowDepth="0" Opacity="0.55" Color="#FFEAB308" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding ScoreLevel}" Value="Critical">
                    <Setter Property="RingBrush" Value="{DynamicResource DangerBrush}" />
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="22" ShadowDepth="0" Opacity="0.6" Color="#FFF87171" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="32,10,32,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <Grid Grid.Row="0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{loc:Loc dashboard.title}" Style="{StaticResource HeaderText}" FontSize="24" />
                <TextBlock Text="{loc:Loc dashboard.subtitle}"
                           Style="{StaticResource MutedText}" Margin="0,4,0,0" />
            </StackPanel>
            <Button Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" VerticalAlignment="Center"
                    Command="{Binding RefreshCommand}">
                <StackPanel Orientation="Horizontal">
                    <Path Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"
                          Fill="{x:Null}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                          Data="M23 4 v6 h-6 M1 20 v-6 h6 M3.51 9 a9 9 0 0 1 14.85 -3.36 L23 10 M1 17 l4.64 4.36 A9 9 0 0 0 20.49 15" />
                    <TextBlock Text="{loc:Loc common.refresh}" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- ===== Lade-Banner (deutlich sichtbar, während im Hintergrund analysiert wird) ===== -->
        <Border Grid.Row="1" Margin="0,18,0,0" CornerRadius="10" Padding="20,15"
                Background="{DynamicResource BgRaisedBrush}"
                BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1.5"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <!-- pulsierender Punkt = „läuft im Hintergrund“ -->
                    <Ellipse Width="12" Height="12" Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Ellipse.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="1" To="0.2" Duration="0:0:0.8" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <TextBlock Text="{loc:Loc dashboard.loadingBanner}"
                               FontSize="14.5" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               VerticalAlignment="Center" Margin="13,0,0,0" />
                </StackPanel>

                <!-- animierter Indeterminate-Balken -->
                <ProgressBar Style="{StaticResource LoadingBar}" Margin="0,13,0,0" />

                <TextBlock Text="{Binding StatusText}" Style="{StaticResource MutedText}"
                           FontSize="12" Margin="0,9,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- ===== Scrollable content ===== -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,22,-12,0" Padding="0,0,12,24">
            <StackPanel>
                <!-- Inhalt wird während des Ladens gedimmt, damit das Banner heraussticht -->
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Opacity" Value="1" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                <Setter Property="Opacity" Value="0.5" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <!-- ===== Score card ===== -->
                <Border Style="{StaticResource Card}" Padding="24" ClipToBounds="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Dezenter Akzent-Glow (füllt bis zum Kartenrand) -->
                        <Rectangle Grid.ColumnSpan="2" Margin="-24" Fill="{DynamicResource HeroGlowBrush}"
                                   IsHitTestVisible="False" />

                        <!-- Left: Score-Ring mit Zahl + Status-Badge -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="{loc:Loc dashboard.tile.score}" Style="{StaticResource TileCaption}"
                                       HorizontalAlignment="Center" />
                            <Grid Width="176" Height="176" Margin="0,10,0,0">
                                <controls:ScoreRing Score="{Binding Score}" Style="{StaticResource ScoreRingStyle}" />
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Score}" Style="{StaticResource ScoreNumberStyle}"
                                               FontSize="52" FontWeight="Bold" FontFamily="{StaticResource MonoFont}"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="/100" Foreground="{DynamicResource TextMutedBrush}"
                                               FontSize="13" FontFamily="{StaticResource MonoFont}"
                                               HorizontalAlignment="Center" Margin="0,-4,0,0" />
                                </StackPanel>
                            </Grid>
                            <Border CornerRadius="9" Padding="12,5" HorizontalAlignment="Center" Margin="0,14,0,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ScoreLevel}" Value="Improvable">
                                                <Setter Property="Background" Value="{DynamicResource WarnBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ScoreLevel}" Value="Critical">
                                                <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding ScoreLabel}" Foreground="{DynamicResource OnAccentBrush}"
                                           FontWeight="SemiBold" FontSize="13" />
                            </Border>
                        </StackPanel>

                        <!-- Right: transparent factor breakdown -->
                        <StackPanel Grid.Column="1" Margin="28,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ScoreExplanation}" Style="{StaticResource MutedText}"
                                       TextWrapping="Wrap" Margin="0,0,0,8" />
                            <ItemsControl ItemsSource="{Binding ScoreFactors}"
                                          Visibility="{Binding HasScoreFactors, Converter={StaticResource BoolToVis}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,9,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <!-- Icon-Chip (Warnung) – Chip bleibt rot („kostet Punkte“),
                                                 das Symbol ist thematisch je Faktor-Art. -->
                                            <Border Grid.Column="0" Width="38" Height="38" CornerRadius="11"
                                                    Background="#26F87171" VerticalAlignment="Top" Margin="0,0,14,0">
                                                <Path Width="19" Height="19" Stretch="Uniform"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Fill="{DynamicResource DangerBrush}">
                                                    <Path.Style>
                                                        <Style TargetType="Path">
                                                            <!-- Standard: Laufwerk (Festplatte) -->
                                                            <Setter Property="Data" Value="M3 5 H21 V11 H3 Z M3 13 H21 V19 H3 Z M18 8 m -0.9 0 a 0.9 0.9 0 1 0 1.8 0 a 0.9 0.9 0 1 0 -1.8 0 M18 16 m -0.9 0 a 0.9 0.9 0 1 0 1.8 0 a 0.9 0.9 0 1 0 -1.8 0" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Kind}" Value="Reclaimable">
                                                                    <Setter Property="Data" Value="M6 2 H18 V6 H6 Z M8 6 H16 L15 21 H9 Z" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Kind}" Value="Startup">
                                                                    <Setter Property="Data" Value="M12 2 C14.5 4.5 16 8.5 16 13 L8 13 C8 8.5 9.5 4.5 12 2 Z M8 11.5 L5 15 L5.5 17.5 L8 15.8 Z M16 11.5 L19 15 L18.5 17.5 L16 15.8 Z M10 16 L12 21 L14 16 Z M12 7 m -1.6 0 a 1.6 1.6 0 1 0 3.2 0 a 1.6 1.6 0 1 0 -3.2 0" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Kind}" Value="Ram">
                                                                    <Setter Property="Data" Value="M6 6 H18 V18 H6 Z M9 3 H10 V6 H9 Z M14 3 H15 V6 H14 Z M9 18 H10 V21 H9 Z M14 18 H15 V21 H14 Z M3 9 H6 V10 H3 Z M3 14 H6 V15 H3 Z M18 9 H21 V10 H18 Z M18 14 H21 V15 H18 Z" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Path.Style>
                                                </Path>
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Description}"
                                                               Foreground="{DynamicResource TextBrush}" FontSize="13.5"
                                                               FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,10,0" />
                                                    <TextBlock Grid.Column="1" Text="{Binding PointsDisplay}"
                                                               Foreground="{DynamicResource DangerBrush}" FontWeight="Bold"
                                                               FontSize="14" FontFamily="{StaticResource MonoFont}"
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                                <Border Height="5" CornerRadius="3" Background="{DynamicResource BgDeepBrush}"
                                                        Margin="0,7,0,0" ClipToBounds="True">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="{Binding BarPercent, Converter={StaticResource PctStar}}" />
                                                            <ColumnDefinition Width="{Binding BarPercent, Converter={StaticResource PctStar}, ConverterParameter=inv}" />
                                                        </Grid.ColumnDefinitions>
                                                        <Rectangle Grid.Column="0" Fill="{DynamicResource DangerBrush}"
                                                                   RadiusX="3" RadiusY="3" />
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                        Visibility="{Binding HasScoreFactors, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                                <Path Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"
                                      Fill="{DynamicResource AccentBrush}" Data="M 0,5 L 4,9 L 11,0" />
                                <TextBlock Text="{loc:Loc dashboard.scorePerfect}" Margin="10,0,0,0"
                                           Foreground="{DynamicResource TextBrush}" FontSize="13" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ===== Stat tiles row ===== -->
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- RAM tile -->
                    <Border Grid.Column="0" Style="{StaticResource HoverCard}" Padding="18">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="{loc:Loc dashboard.tile.ram}" Style="{StaticResource TileCaption}"
                                           VerticalAlignment="Center" />
                                <Path Width="18" Height="18" Stretch="Uniform" HorizontalAlignment="Right"
                                      Fill="{DynamicResource AccentBrush}"
                                      Data="M6 6 H18 V18 H6 Z M9 3 H10 V6 H9 Z M14 3 H15 V6 H14 Z M9 18 H10 V21 H9 Z M14 18 H15 V21 H14 Z M3 9 H6 V10 H3 Z M3 14 H6 V15 H3 Z M18 9 H21 V10 H18 Z M18 14 H21 V15 H18 Z" />
                            </Grid>
                            <TextBlock Text="{Binding RamPercentDisplay}" FontSize="30" FontWeight="Bold"
                                       FontFamily="{StaticResource MonoFont}" Margin="0,4,0,0" />
                            <Border Height="6" CornerRadius="3" Background="{DynamicResource BgDeepBrush}"
                                    Margin="0,10,0,0" ClipToBounds="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{Binding RamPercent, Converter={StaticResource PctStar}}" />
                                        <ColumnDefinition Width="{Binding RamFreePercent, Converter={StaticResource PctStar}}" />
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0" Fill="{DynamicResource AccentBrush}" RadiusX="3" RadiusY="3" />
                                </Grid>
                            </Border>
                            <TextBlock Text="{Binding RamSummary}" Style="{StaticResource MutedText}"
                                       FontSize="11.5" Margin="0,10,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- Speicher tile -->
                    <Border Grid.Column="2" Style="{StaticResource HoverCard}" Padding="18">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="{loc:Loc dashboard.tile.storage}" Style="{StaticResource TileCaption}"
                                           VerticalAlignment="Center" />
                                <Path Width="18" Height="18" Stretch="Uniform" HorizontalAlignment="Right"
                                      Fill="{DynamicResource AccentBrush}"
                                      Data="M3 5 H21 V11 H3 Z M3 13 H21 V19 H3 Z M18 8 m -0.9 0 a 0.9 0.9 0 1 0 1.8 0 a 0.9 0.9 0 1 0 -1.8 0 M18 16 m -0.9 0 a 0.9 0.9 0 1 0 1.8 0 a 0.9 0.9 0 1 0 -1.8 0" />
                            </Grid>
                            <TextBlock Text="{Binding DriveCountDisplay}"
                                       FontSize="24" FontWeight="Bold" Margin="0,4,0,0" />
                            <TextBlock Text="{Binding DrivesSummary}" Style="{StaticResource MutedText}"
                                       FontSize="11.5" Margin="0,8,0,0" TextWrapping="Wrap" />
                            <Button Content="{loc:Loc dashboard.viewDetails}" Style="{StaticResource SecondaryButton}"
                                    Padding="12,7" FontSize="12" HorizontalAlignment="Left" Margin="0,12,0,0"
                                    Command="{Binding OpenSystemCommand}" />
                        </StackPanel>
                    </Border>

                    <!-- Autostart tile -->
                    <Border Grid.Column="4" Style="{StaticResource HoverCard}" Padding="18">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="{loc:Loc dashboard.tile.startup}" Style="{StaticResource TileCaption}"
                                           VerticalAlignment="Center" />
                                <Path Width="18" Height="18" Stretch="Uniform" HorizontalAlignment="Right"
                                      Fill="{DynamicResource AccentBrush}"
                                      Data="M12 2 C14.5 4.5 16 8.5 16 13 L8 13 C8 8.5 9.5 4.5 12 2 Z M8 11.5 L5 15 L5.5 17.5 L8 15.8 Z M16 11.5 L19 15 L18.5 17.5 L16 15.8 Z M10 16 L12 21 L14 16 Z M12 7 m -1.6 0 a 1.6 1.6 0 1 0 3.2 0 a 1.6 1.6 0 1 0 -3.2 0" />
                            </Grid>
                            <TextBlock Text="{Binding StartupEnabled}" FontSize="30" FontWeight="Bold"
                                       FontFamily="{StaticResource MonoFont}" Margin="0,4,0,0" />
                            <TextBlock Text="{Binding StartupSummary}" Style="{StaticResource MutedText}"
                                       FontSize="11.5" Margin="0,8,0,0" TextWrapping="Wrap" />
                            <Button Content="{loc:Loc dashboard.openStartup}" Style="{StaticResource SecondaryButton}"
                                    Padding="12,7" FontSize="12" HorizontalAlignment="Left" Margin="0,12,0,0"
                                    Command="{Binding OpenStartupCommand}" />
                        </StackPanel>
                    </Border>

                    <!-- Temp tile (akzentuiert = primärer Handlungspfad) -->
                    <Border Grid.Column="6" Style="{StaticResource HoverCard}" Padding="18"
                            Background="{DynamicResource AccentSoftBrush}" BorderBrush="{DynamicResource AccentBrush}">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="{loc:Loc dashboard.tile.reclaimable}" Style="{StaticResource TileCaption}"
                                           Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
                                <Path Width="18" Height="18" Stretch="Uniform" HorizontalAlignment="Right"
                                      Fill="{DynamicResource AccentBrush}"
                                      Data="M6 2 H18 V6 H6 Z M8 6 H16 L15 21 H9 Z" />
                            </Grid>
                            <TextBlock Text="{Binding TempReclaimable}" FontSize="30" FontWeight="Bold"
                                       FontFamily="{StaticResource MonoFont}" Foreground="{DynamicResource AccentBrush}"
                                       Margin="0,4,0,0" />
                            <TextBlock Text="{Binding TempSummary}" Style="{StaticResource MutedText}"
                                       FontSize="11.5" Margin="0,8,0,0" TextWrapping="Wrap" />
                            <Button Content="{loc:Loc common.clean}" Style="{StaticResource SecondaryButton}"
                                    Padding="12,7" FontSize="12" HorizontalAlignment="Left" Margin="0,12,0,0"
                                    Command="{Binding OpenCleanerCommand}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ===== Recommendations ===== -->
                <Border Style="{StaticResource Card}" Padding="22" Margin="0,16,0,0">
                    <StackPanel>
                        <!-- Kopf: Glühbirne + Titel + Zähler links, „Alle ausführen“ rechts -->
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"
                                      Fill="{DynamicResource AccentBrush}"
                                      Data="M12 2 C8.7 2 6 4.7 6 8 C6 10.4 7.2 12.3 9 13.5 V16 H15 V13.5 C16.8 12.3 18 10.4 18 8 C18 4.7 15.3 2 12 2 Z M9 17 H15 V18.5 H9 Z M10 19.5 H14 V21 H10 Z" />
                                <TextBlock Text="{loc:Loc dashboard.recommendations}" Style="{StaticResource HeaderText}"
                                           FontSize="16" VerticalAlignment="Center" Margin="10,0,0,0" />
                                <Border Background="{DynamicResource BgRaisedBrush}" CornerRadius="9" Padding="9,2"
                                        VerticalAlignment="Center" Margin="10,1,0,0">
                                    <TextBlock Text="{Binding RecommendationCount}" Foreground="{DynamicResource TextMutedBrush}"
                                               FontSize="12" FontWeight="SemiBold" FontFamily="{StaticResource MonoFont}" />
                                </Border>
                            </StackPanel>

                            <!-- „Alle ausführen →“ (nur wenn es ausführbare Empfehlungen gibt) -->
                            <Button HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand"
                                    Command="{Binding RunAllRecommendationsCommand}"
                                    Visibility="{Binding HasActionableRecommendations, Converter={StaticResource BoolToVis}}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="lb" Background="Transparent" CornerRadius="8" Padding="10,6">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="lt" Text="{loc:Loc dashboard.runAll}"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                <Path x:Name="la" Width="15" Height="12" Stretch="Uniform" Margin="8,0,0,0"
                                                      VerticalAlignment="Center" Fill="{x:Null}"
                                                      Stroke="{DynamicResource TextMutedBrush}" StrokeThickness="2"
                                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                                      Data="M4 12 H20 M14 6 L20 12 L14 18" />
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="lb" Property="Background" Value="{DynamicResource BgRaisedBrush}" />
                                                <Setter TargetName="lt" Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                                <Setter TargetName="la" Property="Stroke" Value="{DynamicResource AccentBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding Recommendations}" Margin="0,12,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource BgRaisedBrush}" CornerRadius="10"
                                            Padding="16,14" Margin="0,5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Icon-Badge: Farbe je Dringlichkeit, Symbol je Art -->
                                            <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12"
                                                    VerticalAlignment="Center" Margin="0,0,14,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource InfoSoftBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Severity}" Value="Critical">
                                                                <Setter Property="Background" Value="{DynamicResource DangerSoftBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                                                <Setter Property="Background" Value="{DynamicResource WarnSoftBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Severity}" Value="Positive">
                                                                <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Path Width="21" Height="21" Stretch="Uniform"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Path.Style>
                                                        <Style TargetType="Path">
                                                            <!-- Farbe je Dringlichkeit -->
                                                            <Setter Property="Fill" Value="{DynamicResource InfoBrush}" />
                                                            <!-- Standardsymbol: Warndreieck (Speicher) -->
                                                            <Setter Property="Data" Value="M12 3 L22 20 L2 20 Z M11 9 H13 V15 H11 Z M11 16.5 H13 V18.5 H11 Z" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Severity}" Value="Critical">
                                                                    <Setter Property="Fill" Value="{DynamicResource DangerBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                                                    <Setter Property="Fill" Value="{DynamicResource WarnBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Severity}" Value="Positive">
                                                                    <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Kind}" Value="Reclaimable">
                                                                    <Setter Property="Data" Value="M6 2 H18 V6 H6 Z M8 6 H16 L15 21 H9 Z" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Kind}" Value="Startup">
                                                                    <Setter Property="Data" Value="M12 2 C14.5 4.5 16 8.5 16 13 L8 13 C8 8.5 9.5 4.5 12 2 Z M8 11.5 L5 15 L5.5 17.5 L8 15.8 Z M16 11.5 L19 15 L18.5 17.5 L16 15.8 Z M10 16 L12 21 L14 16 Z M12 7 m -1.6 0 a 1.6 1.6 0 1 0 3.2 0 a 1.6 1.6 0 1 0 -3.2 0" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Kind}" Value="Ram">
                                                                    <Setter Property="Data" Value="M6 6 H18 V18 H6 Z M9 3 H10 V6 H9 Z M14 3 H15 V6 H14 Z M9 18 H10 V21 H9 Z M14 18 H15 V21 H14 Z M3 9 H6 V10 H3 Z M3 14 H6 V15 H3 Z M18 9 H21 V10 H18 Z M18 14 H21 V15 H18 Z" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Kind}" Value="AllGood">
                                                                    <Setter Property="Data" Value="M9 16.2 L4.8 12 L3.4 13.4 L9 19 L21 7 L19.6 5.6 Z" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Path.Style>
                                                </Path>
                                            </Border>

                                            <!-- Titel + Status-Tag, darunter Beschreibung -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold"
                                                               VerticalAlignment="Center" TextWrapping="Wrap" />
                                                    <Border CornerRadius="6" Padding="8,2" Margin="10,0,0,0"
                                                            VerticalAlignment="Center">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="{DynamicResource InfoSoftBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Severity}" Value="Critical">
                                                                        <Setter Property="Background" Value="{DynamicResource DangerSoftBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                                                        <Setter Property="Background" Value="{DynamicResource WarnSoftBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Severity}" Value="Positive">
                                                                        <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding SeverityTag}" FontSize="11" FontWeight="SemiBold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{DynamicResource InfoBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Severity}" Value="Critical">
                                                                            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                                                            <Setter Property="Foreground" Value="{DynamicResource WarnBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Severity}" Value="Positive">
                                                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Text}" Style="{StaticResource MutedText}"
                                                           FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />
                                            </StackPanel>

                                            <!-- Kennzahl + Einheit -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="16,0,0,0"
                                                        Visibility="{Binding HasValue, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="{Binding ValueDisplay}" HorizontalAlignment="Right"
                                                           FontSize="17" FontWeight="Bold" FontFamily="{StaticResource MonoFont}" />
                                                <TextBlock Text="{Binding ValueUnit}" Style="{StaticResource MutedText}"
                                                           FontSize="11" HorizontalAlignment="Right" Margin="0,2,0,0" />
                                            </StackPanel>

                                            <Button Grid.Column="3" Content="{Binding ActionLabel}"
                                                    Style="{StaticResource SecondaryButton}" Padding="18,9" FontSize="13"
                                                    VerticalAlignment="Center" Margin="16,0,0,0"
                                                    Command="{Binding ActionCommand}"
                                                    Visibility="{Binding HasAction, Converter={StaticResource BoolToVis}}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- ===== Status ===== -->
                <StackPanel Orientation="Horizontal" Margin="2,14,0,0">
                    <ProgressBar Style="{StaticResource LoadingBar}" Width="140" VerticalAlignment="Center"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Text="{Binding StatusText}" Style="{StaticResource MutedText}"
                               FontSize="12" VerticalAlignment="Center" Margin="12,0,0,0" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
