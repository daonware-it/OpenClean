<UserControl x:Class="OpenClean.Views.LockedSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="clr-namespace:OpenClean.Services.Localization"
             mc:Ignorable="d"
             d:DesignHeight="760" d:DesignWidth="900"
             Background="{DynamicResource BgBrush}"
             FontFamily="{StaticResource AppFont}">

    <Grid Margin="32,10,32,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <StackPanel Grid.Row="0" VerticalAlignment="Center">
            <TextBlock Text="{loc:Loc schedule.title}" Style="{StaticResource HeaderText}" FontSize="24" />
            <TextBlock Text="{loc:Loc schedule.subtitle}"
                       Style="{StaticResource MutedText}" Margin="0,4,0,0" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,18,0,0" Padding="0,0,8,0">
            <StackPanel MaxWidth="640" HorizontalAlignment="Left">

                <!-- ===== Premium-Pitch ===== -->
                <Border Style="{StaticResource Card}" Padding="26,24"
                        Visibility="{Binding ShowPurchase, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="42" Height="42" CornerRadius="10"
                                    Background="{DynamicResource BgRaisedBrush}" VerticalAlignment="Center">
                                <TextBlock Text="&#x1F512;" FontSize="18" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="{loc:Loc premium.locked.title}" FontSize="17" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Margin="14,0,0,0" />
                        </StackPanel>

                        <TextBlock Text="{loc:Loc premium.locked.schedule.pitch}" TextWrapping="Wrap"
                                   Style="{StaticResource MutedText}" FontSize="13" LineHeight="20"
                                   Margin="0,14,0,0" />
                        <TextBlock Text="{loc:Loc premium.locked.body}" TextWrapping="Wrap"
                                   Style="{StaticResource MutedText}" FontSize="12.5" LineHeight="19"
                                   Margin="0,10,0,0" />

                        <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                            <Button Content="{loc:Loc premium.action.buy}" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding BuyCommand}" />
                            <Button Content="{loc:Loc premium.action.activate}" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding ActivateCommand}" Margin="12,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ===== Lizenz vorhanden, Modul fehlt ===== -->
                <Border Style="{StaticResource Card}" Padding="26,24"
                        Visibility="{Binding IsModuleMissing, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc premium.module.missingTitle}" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="{loc:Loc premium.module.missingBody}" TextWrapping="Wrap"
                                   Style="{StaticResource MutedText}" FontSize="12.5" Margin="0,8,0,0" />
                        <Button Content="{loc:Loc premium.module.retry}" Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Left" Margin="0,16,0,0"
                                Command="{Binding RetryModuleCommand}" />
                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding StatusText}" Style="{StaticResource MutedText}"
                           FontSize="12.5" Margin="2,14,0,10" TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
