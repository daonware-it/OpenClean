<UserControl x:Class="OpenClean.Views.DeepCleanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:OpenClean.Views"
             xmlns:loc="clr-namespace:OpenClean.Services.Localization"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900"
             Background="{DynamicResource BgBrush}"
             FontFamily="{DynamicResource AppFont}">
    <Grid Margin="32,10,32,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <Grid Grid.Row="0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{loc:Loc deepclean.title}" Style="{StaticResource HeaderText}" FontSize="24" />
                <TextBlock Text="{loc:Loc deepclean.subtitle}"
                           Style="{StaticResource MutedText}" Margin="0,4,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Style="{StaticResource SecondaryButton}" Command="{Binding AnalyzeCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"
                              Fill="{x:Null}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Data="M11 5 a6 6 0 1 0 0 12 a6 6 0 1 0 0 -12 Z M20.5 20.5 L15.8 15.8" />
                        <TextBlock Text="{loc:Loc deepclean.action.analyze}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelCommand}" Margin="12,0,0,0"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                        Content="{loc:Loc deepclean.action.cancel}" />
                <Button Style="{StaticResource PrimaryButton}" Command="{Binding CleanCommand}" Margin="12,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M6 2 L18 2 L18 6 L6 6 Z M8 6 L16 6 L15 21 L9 21 Z" />
                        <TextBlock Text="{loc:Loc deepclean.action.clean}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ===== Banner: Integritätssperre / Ergebnis / Auswahl ===== -->
        <StackPanel Grid.Row="1">

            <!-- Bereinigen ist gesperrt (OPCL-20) -->
            <Border Margin="0,22,0,0" Padding="20,14" CornerRadius="10"
                    Background="{DynamicResource WarnSoftBrush}"
                    BorderBrush="{DynamicResource WarnBrush}" BorderThickness="1"
                    Visibility="{Binding IsIntegrityBlocked, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{loc:Loc deepclean.integrity.blocked}" TextWrapping="Wrap"
                           Foreground="{DynamicResource WarnBrush}" FontSize="13" FontWeight="SemiBold" />
            </Border>

            <!-- Ergebnis-Banner nach dem Bereinigen -->
            <Border Margin="0,22,0,0" Padding="20,14" CornerRadius="10"
                    Background="{DynamicResource AccentBrush}"
                    Visibility="{Binding HasReport, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"
                          Stroke="{DynamicResource OnAccentBrush}" StrokeThickness="2.5" Data="M 0,6 L 5,11 L 14,0"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                    <TextBlock Text="{Binding LastReportText}" Margin="14,0,0,0" VerticalAlignment="Center"
                               Foreground="{DynamicResource OnAccentBrush}" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Auswahl-Zusammenfassung -->
            <Border Style="{StaticResource Card}" Margin="0,22,0,0" Padding="22,18" ClipToBounds="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Rectangle Grid.ColumnSpan="2" Margin="-22,-18" Fill="{DynamicResource HeroGlowBrush}"
                               IsHitTestVisible="False" />
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{loc:Loc deepclean.selectedLabel}" Style="{StaticResource MutedText}"
                                   FontSize="11.5" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SelectionSummary}" FontSize="19" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="{loc:Loc deepclean.action.selectAll}" Style="{StaticResource SecondaryButton}"
                                Padding="12,6" FontSize="12.5" Command="{Binding SelectAllCommand}" />
                        <Button Content="{loc:Loc deepclean.action.deselectAll}" Style="{StaticResource SecondaryButton}"
                                Padding="12,6" FontSize="12.5" Margin="10,0,0,0" Command="{Binding DeselectAllCommand}" />
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>

        <!-- ===== Bereichsliste ===== -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,18,0,0" Padding="0,0,8,0">
            <ItemsControl ItemsSource="{Binding Areas}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,12" Padding="20,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Auswahl: nur analysierte Bereiche mit Inhalt sind wählbar -->
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          IsEnabled="{Binding CanSelect}"
                                          VerticalAlignment="Center" Margin="0,0,16,0" />

                                <!-- Name + Beschreibung + Meldung -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontSize="14.5" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                        <Border CornerRadius="6" Padding="7,1" Margin="9,0,0,0" VerticalAlignment="Center"
                                                Background="#26EAB308">
                                            <TextBlock Text="ADMIN" FontSize="9.5" FontWeight="Bold"
                                                       Foreground="{DynamicResource WarnBrush}" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Description}" Style="{StaticResource MutedText}"
                                               FontSize="11.5" Margin="0,3,0,0" TextWrapping="Wrap" />
                                    <!-- Normale Meldung -->
                                    <TextBlock Text="{Binding Message}" Style="{StaticResource MutedText}"
                                               FontSize="11.5" Margin="0,5,0,0" TextWrapping="Wrap"
                                               Visibility="{Binding HasProblem, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                                    <!-- Problem-Meldung (Rechte, Werkzeugfehler, Zeitlimit) -->
                                    <TextBlock Text="{Binding Message}" FontSize="11.5" Margin="0,5,0,0"
                                               TextWrapping="Wrap" FontWeight="SemiBold"
                                               Foreground="{DynamicResource WarnBrush}"
                                               Visibility="{Binding HasProblem, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>

                                <!-- Größe VOR der Bereinigung + Aktivitätsanzeige.
                                     „Belegt" und „freigebbar" sind zwei verschiedene Aussagen: Die große
                                     Zahl ist das FREIGEBBARE, die Beschriftung darüber sagt das auch so,
                                     und der belegte Platz steht als eigene Zeile darunter. Ohne diese
                                     Trennung las sich „0 B" bei den Schattenkopien als „da liegt nichts" –
                                     obwohl vssadmin dort 7,98 GB belegt meldet. -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding SizeLabel}" Style="{StaticResource MutedText}"
                                               FontSize="9.5" FontWeight="SemiBold" HorizontalAlignment="Right"
                                               Margin="0,0,0,2"
                                               Visibility="{Binding HasSizeLabel, Converter={StaticResource BoolToVis}}" />
                                    <TextBlock Text="{Binding SizeDisplay}" FontSize="17" FontWeight="Bold"
                                               FontFamily="{StaticResource MonoFont}" HorizontalAlignment="Right" />
                                    <TextBlock Text="{Binding OccupiedDisplay}" Style="{StaticResource MutedText}"
                                               FontSize="10.5" HorizontalAlignment="Right" Margin="0,3,0,0"
                                               Visibility="{Binding HasOccupiedInfo, Converter={StaticResource BoolToVis}}" />
                                    <TextBlock Text="{loc:Loc deepclean.busy}" Style="{StaticResource MutedText}"
                                               FontSize="10.5" HorizontalAlignment="Right" Margin="0,3,0,0"
                                               Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ===== Status + Fortschritt ===== -->
        <Border Grid.Row="3" Background="{DynamicResource BgDeepBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Margin="-32,14,-32,0" Padding="32,12">
            <StackPanel>
                <Grid Margin="0,0,0,8" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding ProgressText}" Style="{StaticResource MutedText}"
                               FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Prozentzahl nur, wo sie gemessen ist: solange der laufende Bereich
                             keinen Fortschritt meldet, stünde dort eine erfundene Zahl. -->
                        <TextBlock Text="{Binding ProgressPercent, StringFormat={}{0:0} %}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center" Margin="12,0,0,0"
                                   Visibility="{Binding ProgressIsIndeterminate, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                        <TextBlock Text="{Binding EtaText}" Style="{StaticResource MutedText}"
                                   FontSize="12" VerticalAlignment="Center" Margin="14,0,0,0" />
                    </StackPanel>
                </Grid>
                <!-- Bestimmt, sobald der laufende Bereich Fortschritt meldet: DISM schreibt einen
                     Balken auf die Standardausgabe (nachgemessen: 26 Werte in 32,6 s), der
                     Sockel der fertigen Bereiche ist ohnehin gezählt. Unbestimmt bleibt es dort,
                     wo es wirklich nichts zu beziffern gibt – vssadmin und die Ordner-Scans. -->
                <ProgressBar Minimum="0" Maximum="100" Height="6" Margin="0,0,0,8"
                             Value="{Binding ProgressPercent, Mode=OneWay}"
                             IsIndeterminate="{Binding ProgressIsIndeterminate, Mode=OneWay}"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                <TextBlock Text="{Binding StatusText}" Style="{StaticResource MutedText}"
                           FontSize="12.5" VerticalAlignment="Center" TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
