<UserControl x:Class="OpenClean.Views.ScheduleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:OpenClean.Views"
             xmlns:loc="clr-namespace:OpenClean.Services.Localization"
             mc:Ignorable="d"
             d:DesignHeight="760" d:DesignWidth="900"
             Background="{DynamicResource BgBrush}"
             FontFamily="{StaticResource AppFont}">
    <UserControl.Resources>
        <local:EnumToBoolConverter x:Key="EnumToBool" />
    </UserControl.Resources>

    <Grid Margin="32,10,32,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <Grid Grid.Row="0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{loc:Loc schedule.title}" Style="{StaticResource HeaderText}" FontSize="24" />
                <TextBlock Text="{loc:Loc schedule.subtitle}"
                           Style="{StaticResource MutedText}" Margin="0,4,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="{loc:Loc schedule.action.runNow}" Style="{StaticResource SecondaryButton}"
                        Command="{Binding RunNowCommand}" />
                <Button Content="{loc:Loc schedule.action.apply}" Style="{StaticResource PrimaryButton}"
                        Command="{Binding ApplyCommand}" Margin="12,0,0,0" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,18,0,0" Padding="0,0,8,0">
            <StackPanel>

                <!-- ===== WARNHINWEIS: keine Rückfrage ===== -->
                <Border Padding="20,16" CornerRadius="10"
                        Background="{DynamicResource BgDeepBrush}"
                        BorderBrush="{DynamicResource DangerBrush}" BorderThickness="1.5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x26A0;" FontSize="20" VerticalAlignment="Top"
                                   Foreground="{DynamicResource DangerBrush}" Margin="0,0,14,0" />
                        <StackPanel>
                            <TextBlock Text="{loc:Loc schedule.warning.title}" FontSize="14.5" FontWeight="SemiBold"
                                       Foreground="{DynamicResource DangerBrush}" />
                            <TextBlock Text="{loc:Loc schedule.warning.body}" TextWrapping="Wrap"
                                       Style="{StaticResource MutedText}" FontSize="12.5" Margin="0,5,0,0"
                                       MaxWidth="640" HorizontalAlignment="Left" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ===== Aktivierung ===== -->
                <Border Style="{StaticResource Card}" Margin="0,18,0,0" Padding="22,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{loc:Loc schedule.enable.label}" FontSize="15" FontWeight="SemiBold" />
                            <TextBlock Text="{loc:Loc schedule.enable.hint}" Style="{StaticResource MutedText}"
                                       FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" MaxWidth="560"
                                       HorizontalAlignment="Left" />
                        </StackPanel>
                        <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"
                                      IsChecked="{Binding IsEnabled, Mode=TwoWay}" />
                    </Grid>
                </Border>

                <!-- ===== Zeitplan ===== -->
                <Border Style="{StaticResource Card}" Margin="0,16,0,0" Padding="22,18">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc schedule.section.when}" Style="{StaticResource MutedText}"
                                   FontSize="11.5" FontWeight="SemiBold" />

                        <!-- Häufigkeit -->
                        <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                            <RadioButton GroupName="Freq" Content="{loc:Loc schedule.freq.daily}" Margin="0,0,20,0"
                                         IsChecked="{Binding Frequency, Mode=TwoWay, Converter={StaticResource EnumToBool}, ConverterParameter=Daily}" />
                            <RadioButton GroupName="Freq" Content="{loc:Loc schedule.freq.weekly}" Margin="0,0,20,0"
                                         IsChecked="{Binding Frequency, Mode=TwoWay, Converter={StaticResource EnumToBool}, ConverterParameter=Weekly}" />
                            <RadioButton GroupName="Freq" Content="{loc:Loc schedule.freq.monthly}"
                                         IsChecked="{Binding Frequency, Mode=TwoWay, Converter={StaticResource EnumToBool}, ConverterParameter=Monthly}" />
                        </StackPanel>

                        <!-- Detailauswahl: Uhrzeit + (Wochentag / Tag des Monats) -->
                        <WrapPanel Margin="0,16,0,0">
                            <!-- Uhrzeit -->
                            <StackPanel Margin="0,0,24,10">
                                <TextBlock Text="{loc:Loc schedule.time.label}" Style="{StaticResource MutedText}"
                                           FontSize="11" Margin="2,0,0,5" />
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox Style="{StaticResource LanguageCombo}" Width="72"
                                              ItemsSource="{Binding Hours}"
                                              SelectedItem="{Binding Hour, Mode=TwoWay}" />
                                    <TextBlock Text=":" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"
                                               Margin="8,0,8,0" />
                                    <ComboBox Style="{StaticResource LanguageCombo}" Width="72"
                                              ItemsSource="{Binding Minutes}"
                                              SelectedItem="{Binding Minute, Mode=TwoWay}" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Wochentag (nur wöchentlich) -->
                            <StackPanel Margin="0,0,24,10"
                                        Visibility="{Binding ShowWeekly, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{loc:Loc schedule.weekday.label}" Style="{StaticResource MutedText}"
                                           FontSize="11" Margin="2,0,0,5" />
                                <ComboBox Style="{StaticResource LanguageCombo}" Width="150"
                                          ItemsSource="{Binding WeekdayNames}"
                                          SelectedIndex="{Binding SelectedWeekdayIndex, Mode=TwoWay}" />
                            </StackPanel>

                            <!-- Tag des Monats (nur monatlich) -->
                            <StackPanel Margin="0,0,24,10"
                                        Visibility="{Binding ShowMonthly, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{loc:Loc schedule.dayOfMonth.label}" Style="{StaticResource MutedText}"
                                           FontSize="11" Margin="2,0,0,5" />
                                <ComboBox Style="{StaticResource LanguageCombo}" Width="90"
                                          ItemsSource="{Binding DaysOfMonth}"
                                          SelectedItem="{Binding DayOfMonth, Mode=TwoWay}" />
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- ===== Profil (was gereinigt wird) ===== -->
                <Border Style="{StaticResource Card}" Margin="0,16,0,0" Padding="22,18">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc schedule.section.what}" Style="{StaticResource MutedText}"
                                   FontSize="11.5" FontWeight="SemiBold" />

                        <StackPanel Margin="0,14,0,0">
                            <RadioButton GroupName="Profile" Margin="0,0,0,10"
                                         IsChecked="{Binding Profile, Mode=TwoWay, Converter={StaticResource EnumToBool}, ConverterParameter=TempOnly}">
                                <StackPanel>
                                    <TextBlock Text="{loc:Loc schedule.profile.tempOnly}" FontWeight="SemiBold" />
                                    <TextBlock Text="{loc:Loc schedule.profile.tempOnly.hint}" Style="{StaticResource MutedText}"
                                               FontSize="11.5" Margin="0,2,0,0" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton GroupName="Profile" Margin="0,0,0,10"
                                         IsChecked="{Binding Profile, Mode=TwoWay, Converter={StaticResource EnumToBool}, ConverterParameter=Full}">
                                <StackPanel>
                                    <TextBlock Text="{loc:Loc schedule.profile.full}" FontWeight="SemiBold" />
                                    <TextBlock Text="{loc:Loc schedule.profile.full.hint}" Style="{StaticResource MutedText}"
                                               FontSize="11.5" Margin="0,2,0,0" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton GroupName="Profile"
                                         IsChecked="{Binding Profile, Mode=TwoWay, Converter={StaticResource EnumToBool}, ConverterParameter=Custom}">
                                <StackPanel>
                                    <TextBlock Text="{loc:Loc schedule.profile.custom}" FontWeight="SemiBold" />
                                    <TextBlock Text="{loc:Loc schedule.profile.custom.hint}" Style="{StaticResource MutedText}"
                                               FontSize="11.5" Margin="0,2,0,0" />
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>

                        <!-- Kategorien für Benutzerdefiniert -->
                        <Border Margin="0,14,0,0" Padding="16,12" CornerRadius="8"
                                Background="{DynamicResource BgDeepBrush}"
                                Visibility="{Binding ShowCustom, Converter={StaticResource BoolToVis}}">
                            <ItemsControl ItemsSource="{Binding Categories}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Name}" Margin="0,5"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ===== Benachrichtigung ===== -->
                <Border Style="{StaticResource Card}" Margin="0,16,0,0" Padding="22,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{loc:Loc schedule.notify.label}" FontSize="15" FontWeight="SemiBold" />
                            <TextBlock Text="{loc:Loc schedule.notify.hint}" Style="{StaticResource MutedText}"
                                       FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" MaxWidth="560"
                                       HorizontalAlignment="Left" />
                        </StackPanel>
                        <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"
                                      IsChecked="{Binding Notify, Mode=TwoWay}" />
                    </Grid>
                </Border>

                <!-- ===== Berichte ===== -->
                <TextBlock Text="{loc:Loc schedule.reports.heading}" Style="{StaticResource HeaderText}"
                           FontSize="16" Margin="2,26,0,0" />
                <TextBlock Text="{loc:Loc schedule.reports.empty}" Style="{StaticResource MutedText}"
                           Margin="2,10,0,0"
                           Visibility="{Binding HasReports, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />

                <ItemsControl ItemsSource="{Binding Reports}" Margin="0,12,0,10"
                              Visibility="{Binding HasReports, Converter={StaticResource BoolToVis}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Expander Margin="0,0,0,10" IsExpanded="False">
                                <Expander.Header>
                                    <Grid VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding When}" FontSize="14" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding ProfileName}" Style="{StaticResource MutedText}"
                                                       FontSize="11.5" Margin="0,2,0,0" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding Summary}" VerticalAlignment="Center"
                                                   HorizontalAlignment="Right" Margin="12,0,12,0"
                                                   FontSize="12.5" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   TextAlignment="Right" TextWrapping="Wrap" />
                                    </Grid>
                                </Expander.Header>
                                <StackPanel Margin="14,0,14,12">
                                    <TextBlock Text="{loc:Loc schedule.report.deletedHeading}"
                                               Style="{StaticResource MutedText}" FontSize="11"
                                               FontWeight="SemiBold" Margin="0,4,0,8"
                                               Visibility="{Binding HasPaths, Converter={StaticResource BoolToVis}}" />
                                    <Border Background="{DynamicResource BgDeepBrush}" CornerRadius="8"
                                            Visibility="{Binding HasPaths, Converter={StaticResource BoolToVis}}">
                                        <ListBox ItemsSource="{Binding DeletedPaths}" MaxHeight="240"
                                                 Background="Transparent" BorderThickness="0" Padding="8"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 VirtualizingStackPanel.IsVirtualizing="True"
                                                 VirtualizingStackPanel.VirtualizationMode="Recycling">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Setter Property="Padding" Value="6,3" />
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" FontSize="11.5"
                                                               Foreground="{DynamicResource TextMutedBrush}"
                                                               TextTrimming="CharacterEllipsis" ToolTip="{Binding}" />
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Border>
                                    <TextBlock Text="{Binding TruncatedNote}" Style="{StaticResource MutedText}"
                                               FontSize="11" Margin="2,8,0,0" TextWrapping="Wrap"
                                               Visibility="{Binding PathsTruncated, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

        <!-- ===== Statusleiste ===== -->
        <Border Grid.Row="2" Background="{DynamicResource BgDeepBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Margin="-32,14,-32,0" Padding="32,12">
            <TextBlock Text="{Binding StatusText}" Style="{StaticResource MutedText}"
                       FontSize="12.5" VerticalAlignment="Center" />
        </Border>
    </Grid>
</UserControl>
