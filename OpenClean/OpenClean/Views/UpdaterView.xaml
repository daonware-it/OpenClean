<UserControl x:Class="OpenClean.Views.UpdaterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:OpenClean.Views"
             xmlns:loc="clr-namespace:OpenClean.Services.Localization"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900"
             Background="{DynamicResource BgBrush}"
             FontFamily="{StaticResource AppFont}">

    <Grid Margin="32,10,32,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <Grid Grid.Row="0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{loc:Loc updater.title}" Style="{StaticResource HeaderText}" FontSize="24" />
                <TextBlock Text="{loc:Loc updater.subtitle}"
                           Style="{StaticResource MutedText}" Margin="0,4,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="{loc:Loc updater.action.updateAll}" Style="{StaticResource PrimaryButton}"
                        VerticalAlignment="Center"
                        Command="{Binding UpdateAllCommand}" />
                <Button Content="{loc:Loc common.refresh}" Style="{StaticResource SecondaryButton}"
                        VerticalAlignment="Center" Margin="12,0,0,0"
                        Command="{Binding RefreshCommand}" />
            </StackPanel>
        </Grid>

        <!-- ===== Lade-/Update-Banner (sichtbar, während im Hintergrund gearbeitet wird) ===== -->
        <Border Grid.Row="1" Margin="0,18,0,0" CornerRadius="10" Padding="20,15"
                Background="{DynamicResource BgRaisedBrush}"
                BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1.5"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <!-- pulsierender Punkt = „läuft im Hintergrund“ -->
                    <Ellipse Width="12" Height="12" Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Ellipse.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="1" To="0.2" Duration="0:0:0.8" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="14.5" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               VerticalAlignment="Center" Margin="13,0,0,0" TextWrapping="Wrap" />
                </StackPanel>

                <!-- Balken: Shimmer beim Scannen/Einzel-Update, determiniert beim Sammel-Update -->
                <ProgressBar Style="{StaticResource LoadingBar}" Margin="0,13,0,0"
                             IsIndeterminate="{Binding ProgressIsIndeterminate, Mode=OneWay}"
                             Value="{Binding ProgressPercent, Mode=OneWay}" Maximum="100" />

                <TextBlock Text="{Binding ProgressText}" Style="{StaticResource MutedText}"
                           FontSize="12" Margin="0,9,0,0" TextWrapping="Wrap"
                           Visibility="{Binding ProgressIsIndeterminate, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
            </StackPanel>
        </Border>

        <!-- ===== winget-Hinweis (nur sichtbar, wenn winget fehlt) ===== -->
        <Border Grid.Row="2" Margin="0,22,0,0" Padding="18,14" CornerRadius="10"
                Background="{DynamicResource BgDeepBrush}"
                BorderBrush="{DynamicResource DangerBrush}" BorderThickness="1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding WingetAvailable}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{loc:Loc updater.status.wingetMissing}" TextWrapping="Wrap"
                       FontSize="12.5" Foreground="{DynamicResource DangerBrush}" />
        </Border>

        <!-- ===== Column header ===== -->
        <Border Grid.Row="2" Margin="0,22,0,0" Padding="18,10" CornerRadius="8,8,0,0"
                Background="{DynamicResource BgDeepBrush}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding WingetAvailable}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{loc:Loc updater.col.program}" Style="{StaticResource MutedText}"
                           FontSize="10.5" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="{loc:Loc updater.col.current}" Style="{StaticResource MutedText}"
                           FontSize="10.5" FontWeight="SemiBold" />
                <TextBlock Grid.Column="2" Text="{loc:Loc updater.col.available}" Style="{StaticResource MutedText}"
                           FontSize="10.5" FontWeight="SemiBold" />
                <TextBlock Grid.Column="3" Text="{loc:Loc updater.col.action}" Style="{StaticResource MutedText}"
                           FontSize="10.5" FontWeight="SemiBold" HorizontalAlignment="Right" />
            </Grid>
        </Border>

        <!-- ===== List ===== -->
        <Border Grid.Row="3" CornerRadius="0,0,10,10"
                BorderThickness="1,0,1,1">
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource Card}">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding WingetAvailable}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="6,4">
                <ItemsControl ItemsSource="{Binding Updates}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="row" Background="Transparent" CornerRadius="8"
                                    Padding="12,12" Margin="0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Name + Id -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Id}" Style="{StaticResource MutedText}"
                                                   FontSize="11.5" Margin="0,3,0,0"
                                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding Id}" />
                                    </StackPanel>

                                    <!-- Aktuelle Version -->
                                    <TextBlock Grid.Column="1" Text="{Binding CurrentVersion}"
                                               VerticalAlignment="Center" FontSize="12.5"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextTrimming="CharacterEllipsis" Margin="0,0,12,0" />

                                    <!-- Verfügbare Version -->
                                    <TextBlock Grid.Column="2" Text="{Binding AvailableVersion}"
                                               VerticalAlignment="Center" FontSize="12.5" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}"
                                               TextTrimming="CharacterEllipsis" Margin="0,0,12,0" />

                                    <!-- Update-Button -->
                                    <Button Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Center"
                                            Content="{loc:Loc updater.action.update}"
                                            Command="{Binding UpdateCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                <Setter Property="IsEnabled" Value="True" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUpdating}" Value="True">
                                                        <Setter Property="IsEnabled" Value="False" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True" SourceName="row">
                                    <Setter TargetName="row" Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
                                </Trigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ===== Status bar ===== -->
        <Border Grid.Row="4" Background="{DynamicResource BgDeepBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Margin="-32,14,-32,0" Padding="32,12">
            <TextBlock Text="{Binding StatusText}" Style="{StaticResource MutedText}"
                       FontSize="12.5" VerticalAlignment="Center" />
        </Border>
    </Grid>
</UserControl>
