<UserControl x:Class="OpenClean.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:OpenClean.Views"
             xmlns:loc="clr-namespace:OpenClean.Services.Localization"
             mc:Ignorable="d"
             d:DesignHeight="760" d:DesignWidth="900"
             Background="{DynamicResource BgBrush}"
             FontFamily="{StaticResource AppFont}">
    <UserControl.Resources>
        <!-- Kleine Karten-Überschrift (wie in Übersicht / Lizenz) -->
        <Style x:Key="TileCaption" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="32,10,32,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <StackPanel Grid.Row="0" VerticalAlignment="Center">
            <TextBlock Text="{loc:Loc settings.title}" Style="{StaticResource HeaderText}" FontSize="24" />
            <TextBlock Text="{loc:Loc settings.subtitle}" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,18,0,0" Padding="0,0,8,0">
            <StackPanel HorizontalAlignment="Stretch">

                <!-- ===== Design (Theme-Grid + Modifier) ===== -->
                <Border Style="{StaticResource Card}" Padding="22,18">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc settings.appearance.palette}" Style="{StaticResource TileCaption}" />

                        <ListBox Margin="0,14,0,0" Background="Transparent" BorderThickness="0"
                                 ItemsSource="{Binding ThemeOptions}"
                                 SelectedValuePath="Theme"
                                 SelectedValue="{Binding SelectedTheme, Mode=TwoWay}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Margin" Value="0,0,10,10" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="tile" CornerRadius="10" Padding="14,10"
                                                        Background="{DynamicResource SurfaceBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1.5"
                                                        Cursor="Hand">
                                                    <StackPanel>
                                                        <!-- Swatch-Reihe: Akzent, Oberfläche, Text -->
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Width="18" Height="18" CornerRadius="4"
                                                                    Background="{DynamicResource AccentBrush}" />
                                                            <Border Width="18" Height="18" CornerRadius="4" Margin="5,0,0,0"
                                                                    Background="{DynamicResource BgRaisedBrush}" />
                                                            <Border Width="18" Height="18" CornerRadius="4" Margin="5,0,0,0"
                                                                    Background="{DynamicResource TextBrush}" />
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding DisplayName}" Margin="0,8,0,0"
                                                                   FontSize="12.5" />
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="tile" Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="tile" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                        <Setter TargetName="tile" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>

                        <!-- Modifier -->
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Loc settings.appearance.windowsAccent}"
                                       FontSize="13.5" VerticalAlignment="Center" />
                            <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding UseWindowsAccent, Mode=TwoWay}" />
                        </Grid>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{loc:Loc settings.appearance.mica}" FontSize="13.5" />
                                <TextBlock Text="{loc:Loc settings.appearance.micaUnsupported}"
                                           Style="{StaticResource MutedText}" FontSize="11" Margin="0,2,0,0"
                                           Visibility="{Binding IsMicaSupported, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                            </StackPanel>
                            <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                          IsEnabled="{Binding IsMicaSupported}"
                                          IsChecked="{Binding UseMicaBackdrop, Mode=TwoWay}" />
                        </Grid>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Loc settings.appearance.reduceMotion}"
                                       FontSize="13.5" VerticalAlignment="Center" />
                            <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding ReduceMotion, Mode=TwoWay}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ===== Sprache ===== -->
                <Border Style="{StaticResource Card}" Padding="22,18" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc settings.language.heading}" Style="{StaticResource TileCaption}" />
                        <TextBlock Text="{loc:Loc settings.language.hint}" Style="{StaticResource MutedText}"
                                   FontSize="11.5" Margin="0,6,0,0" TextWrapping="Wrap" />
                        <!-- Bindet direkt an den Lokalisierungs-Singleton (wie zuvor im Sidebar-Footer). -->
                        <ComboBox Style="{StaticResource LanguageCombo}" Margin="0,12,0,0" MaxWidth="260"
                                  HorizontalAlignment="Left"
                                  ItemsSource="{Binding Languages, Source={x:Static loc:LocalizationManager.Instance}}"
                                  SelectedItem="{Binding CurrentLanguageOption, Source={x:Static loc:LocalizationManager.Instance}, Mode=TwoWay}" />
                    </StackPanel>
                </Border>

                <!-- ===== Lizenz ===== -->
                <!-- Bestehende LicenseView, gehostet mit der aus dem MainViewModel durchgereichten
                     Instanz. Aktivierung/Freigabe laufen unverändert über deren Commands/Dialoge.
                     Die View ist ein reiner Inhaltsblock (ohne eigenen Header/ScrollViewer), daher
                     reiht sie sich wie eine weitere Karte in denselben ScrollViewer ein und teilt
                     sich dessen Breite. -->
                <TextBlock Text="{loc:Loc license.title}" Style="{StaticResource TileCaption}" Margin="2,22,0,0" />
                <views:LicenseView DataContext="{Binding License}" Margin="0,10,0,0" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
