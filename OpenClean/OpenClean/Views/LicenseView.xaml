<UserControl x:Class="OpenClean.Views.LicenseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="clr-namespace:OpenClean.Services.Localization"
             mc:Ignorable="d"
             d:DesignHeight="760" d:DesignWidth="900"
             Background="{DynamicResource BgBrush}"
             FontFamily="{StaticResource AppFont}">
    <UserControl.Resources>
        <!-- Kleine Karten-Überschrift (wie in Übersicht / Speicher & RAM) -->
        <Style x:Key="TileCaption" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- Beschriftung einer Detailzeile -->
        <Style x:Key="DetailLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Wert einer Detailzeile (Zahlen/Schlüssel monospaced) -->
        <Style x:Key="DetailValue" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Right" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="32,10,32,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <StackPanel Grid.Row="0" VerticalAlignment="Center">
            <TextBlock Text="{loc:Loc license.title}" Style="{StaticResource HeaderText}" FontSize="24" />
            <TextBlock Text="{loc:Loc license.subtitle}" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,18,0,0" Padding="0,0,8,0">
            <StackPanel MaxWidth="640" HorizontalAlignment="Left">

                <!-- ===== Status (Hero) ===== -->
                <Border Style="{StaticResource Card}" Padding="26,24">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="42" Height="42" CornerRadius="10"
                                    Background="{DynamicResource AccentSoftBrush}" VerticalAlignment="Center">
                                <!-- Stern: Premium -->
                                <Path Width="18" Height="18" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Fill="{DynamicResource AccentBrush}"
                                      Data="M12 2 L15 9 L22 9.5 L17 14 L18.5 21 L12 17.5 L5.5 21 L7 14 L2 9.5 L9 9 Z" />
                            </Border>
                            <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                                <TextBlock Text="{Binding StateTitle}" FontSize="17" FontWeight="SemiBold" />
                                <TextBlock Text="{loc:Loc license.sidebar.title}" Style="{StaticResource MutedText}"
                                           FontSize="11.5" Margin="0,2,0,0" />
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="{Binding StateBody}" TextWrapping="Wrap"
                                   Style="{StaticResource MutedText}" FontSize="13" LineHeight="20"
                                   Margin="0,14,0,0" />

                        <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                            <Button Content="{loc:Loc premium.action.activate}" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding ActivateCommand}"
                                    Visibility="{Binding ShowPurchase, Converter={StaticResource BoolToVis}}" />
                            <Button Content="{loc:Loc premium.action.buy}" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding BuyCommand}" Margin="12,0,0,0"
                                    Visibility="{Binding ShowPurchase, Converter={StaticResource BoolToVis}}" />
                            <Button Content="{loc:Loc license.action.deactivate}" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding DeactivateCommand}"
                                    Visibility="{Binding HasLicense, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ===== Lizenzdetails (nur mit gespeichertem Schlüssel) ===== -->
                <Border Style="{StaticResource Card}" Padding="22,18" Margin="0,16,0,0"
                        Visibility="{Binding HasLicense, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc license.details.heading}" Style="{StaticResource TileCaption}" />

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Loc license.details.key}" Style="{StaticResource DetailLabel}" />
                            <TextBlock Grid.Column="1" Text="{Binding MaskedKey}" Style="{StaticResource DetailValue}" />
                        </Grid>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Loc license.details.edition}" Style="{StaticResource DetailLabel}" />
                            <TextBlock Grid.Column="1" Text="{Binding Edition}" Style="{StaticResource DetailValue}" />
                        </Grid>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Loc license.details.expires}" Style="{StaticResource DetailLabel}" />
                            <TextBlock Grid.Column="1" Text="{Binding ExpiresText}" Style="{StaticResource DetailValue}" />
                        </Grid>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Loc license.details.moduleVersion}" Style="{StaticResource DetailLabel}" />
                            <TextBlock Grid.Column="1" Text="{Binding ModuleVersion}" Style="{StaticResource DetailValue}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ===== Pro-Funktionen ===== -->
                <Border Style="{StaticResource Card}" Padding="22,18" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc license.features.heading}" Style="{StaticResource TileCaption}" />

                        <!-- Zeitplan -->
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center">
                                <!-- Häkchen: freigeschaltet -->
                                <Path Width="14" Height="12" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Fill="{x:Null}" Stroke="{DynamicResource AccentBrush}"
                                      StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M 0,6 L 5,11 L 14,0"
                                      Visibility="{Binding HasSchedule, Converter={StaticResource BoolToVis}}" />
                                <!-- Schloss: gesperrt -->
                                <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="{Binding HasSchedule, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                            </Grid>
                            <TextBlock Grid.Column="1" Text="{loc:Loc license.features.schedule}"
                                       FontSize="13.5" VerticalAlignment="Center" />
                        </Grid>

                        <!-- Batch-Deinstallation -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center">
                                <Path Width="14" Height="12" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Fill="{x:Null}" Stroke="{DynamicResource AccentBrush}"
                                      StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M 0,6 L 5,11 L 14,0"
                                      Visibility="{Binding HasBatchUninstall, Converter={StaticResource BoolToVis}}" />
                                <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="{Binding HasBatchUninstall, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                            </Grid>
                            <TextBlock Grid.Column="1" Text="{loc:Loc license.features.batchUninstall}"
                                       FontSize="13.5" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding StatusText}" Style="{StaticResource MutedText}"
                           FontSize="12.5" Margin="2,14,0,10" TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
