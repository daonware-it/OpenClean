<?xml version="1.0" encoding="utf-8"?>
<!--
  Publish-Profil "Portable" (v0.11.0).
  Erzeugt eine einzelne, self-contained EXE (kein installiertes .NET nötig),
  die direkt vom USB-Stick läuft. Bewusst NICHT in der .csproj hinterlegt,
  damit normale Dev-/F5-Builds schlank und framework-abhängig bleiben.

  Aufruf:
    dotnet publish OpenClean\OpenClean.csproj -p:PublishProfile=Portable
  (siehe build\publish-portable.ps1)
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <!-- Zwingend: bettet die native e_sqlite3.dll (SQLitePCLRaw) in die Single-File-EXE
         ein und entpackt sie zur Laufzeit. Ohne dies scheitert der SQLite-Zugriff
         (Browser-Verlauf/Cookies) im Portable-Build. -->
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <!-- ReadyToRun vergrößert die EXE deutlich; für ein Portable-Tool nicht nötig. -->
    <PublishReadyToRun>false</PublishReadyToRun>
  </PropertyGroup>
</Project>
