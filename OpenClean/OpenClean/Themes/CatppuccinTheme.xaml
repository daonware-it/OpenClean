<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============ Catppuccin Mocha ============ -->
    <Color x:Key="BgDeepColor">#FF181825</Color>
    <Color x:Key="BgColor">#FF1E1E2E</Color>
    <Color x:Key="BgRaisedColor">#FF313244</Color>
    <Color x:Key="SurfaceColor">#FF313244</Color>
    <Color x:Key="SurfaceHoverColor">#FF45475A</Color>
    <Color x:Key="BorderColor">#FF45475A</Color>
    <Color x:Key="AccentColor">#FFCBA6F7</Color>
    <Color x:Key="AccentDarkColor">#FFB48EE0</Color>
    <Color x:Key="AccentSoftColor">#26CBA6F7</Color>
    <Color x:Key="OnAccentColor">#FF0C201A</Color>
    <Color x:Key="TextColor">#FFCDD6F4</Color>
    <Color x:Key="TextMutedColor">#FFA6ADC8</Color>
    <Color x:Key="DangerColor">#FFF38BA8</Color>
    <Color x:Key="WarnColor">#FFF9E2AF</Color>
    <Color x:Key="InfoColor">#FF89B4FA</Color>

    <SolidColorBrush x:Key="BgDeepBrush" Color="{StaticResource BgDeepColor}" />
    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}" />
    <SolidColorBrush x:Key="BgRaisedBrush" Color="{StaticResource BgRaisedColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource SurfaceHoverColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDarkColor}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoftColor}" />
    <SolidColorBrush x:Key="OnAccentBrush" Color="{StaticResource OnAccentColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="WarnBrush" Color="{StaticResource WarnColor}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}" />

    <!-- Weiche Tönungen für Icon-Badges/Status-Tags (Empfehlungen). -->
    <SolidColorBrush x:Key="DangerSoftBrush" Color="#26F38BA8" />
    <SolidColorBrush x:Key="WarnSoftBrush" Color="#26F9E2AF" />
    <SolidColorBrush x:Key="InfoSoftBrush" Color="#2689B4FA" />

    <!-- Dezenter Akzent-Glow für Hero-Karten (oben rechts, nach außen transparent). -->
    <RadialGradientBrush x:Key="HeroGlowBrush"
                         GradientOrigin="0.85,0.12" Center="0.85,0.12"
                         RadiusX="0.85" RadiusY="1.3">
        <GradientStop Color="#30CBA6F7" Offset="0" />
        <GradientStop Color="#00CBA6F7" Offset="1" />
    </RadialGradientBrush>

</ResourceDictionary>
