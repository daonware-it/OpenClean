<Window x:Class="OpenClean.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OpenClean"
        xmlns:views="clr-namespace:OpenClean.Views"
        xmlns:loc="clr-namespace:OpenClean.Services.Localization"
        mc:Ignorable="d"
        Title="OpenClean" Icon="Resources/openclean.png" Height="760" Width="1180"
        MinHeight="620" MinWidth="980"
        Background="{DynamicResource WindowBackdropBrush}"
        WindowStartupLocation="CenterScreen"
        FontFamily="{StaticResource AppFont}">
    <!-- Eigene Titelleiste: Standard-Chrome ausblenden, Drag/Resize/Snap bleiben erhalten -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" ResizeBorderThickness="6"
                      GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <views:EnumToBoolConverter x:Key="EnumToBool" />
    </Window.Resources>
    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="248" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ================= Titelleiste (Inhalt-Spalte) ================= -->
        <Grid Grid.Row="0" Grid.Column="1" Background="{DynamicResource WindowBackdropBrush}">
            <!-- Dev-Theme: blinkender Terminal-Cursor (Prompt-Charakter), nur bei Dev sichtbar. -->
            <TextBlock x:Name="DevCaret" Text="_" FontFamily="{StaticResource MonoFont}"
                       FontSize="16" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"
                       VerticalAlignment="Center" HorizontalAlignment="Left" Margin="16,0,0,0"
                       IsHitTestVisible="False" Visibility="Collapsed" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <!-- Zahnrad: öffnet den zentralen Einstellungsbereich (Design, Sprache, Lizenz). -->
                <Button Style="{StaticResource WindowControlButton}" Click="SettingsButton_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True" ToolTip="{loc:Loc titlebar.settings}">
                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                </Button>
                <Button Style="{StaticResource WindowControlButton}" Click="MinimizeButton_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True" ToolTip="{loc:Loc titlebar.minimize}">
                    <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                </Button>
                <Button Style="{StaticResource WindowControlButton}" Click="MaximizeButton_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True" ToolTip="{loc:Loc titlebar.maximize}">
                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10"
                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="&#xE922;" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Value="Maximized">
                                        <Setter Property="Text" Value="&#xE923;" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>
                <Button Style="{StaticResource WindowCloseButton}" Click="CloseButton_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True" ToolTip="{loc:Loc titlebar.close}">
                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- ================= Sidebar ================= -->
        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Background="{DynamicResource BgDeepBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Brand -->
                <StackPanel DockPanel.Dock="Top" Margin="22,26,20,20">
                    <StackPanel Orientation="Horizontal">
                        <!-- App-Logo (Resources\openclean.png). -->
                        <Image Source="Resources/openclean.png" Width="36" Height="36"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <TextBlock Text="{Binding AppTitle}" FontSize="21" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="12,0,0,0" />
                    </StackPanel>
                    <TextBlock Text="{Binding AppTagline}" Style="{StaticResource MutedText}"
                               TextWrapping="Wrap" FontSize="11.5" Margin="1,12,0,0" LineHeight="17" />
                </StackPanel>

                <!-- Footer -->
                <StackPanel DockPanel.Dock="Bottom" Margin="24,0,20,18">
                    <!-- Lizenz/Pro sowie Design- und Sprachauswahl sind in den zentralen
                         Einstellungsbereich (Zahnrad in der Titelleiste) umgezogen. Eine feine
                         Trennlinie setzt den Versionshinweis von der Navigationsliste ab. -->
                    <Border Height="1" Background="{DynamicResource BorderBrush}"
                            Opacity="0.6" Margin="0,0,0,14" />

                    <TextBlock Text="{Binding SidebarVersion}" Style="{StaticResource MutedText}"
                               FontSize="11" Margin="1,0,0,0" />
                </StackPanel>

                <!-- Nav: in ScrollViewer, damit bei kleiner Fensterhöhe (z.B. MinHeight) alle Einträge
                     trotz der Pro-Karte im Footer erreichbar bleiben, statt vom Footer überlappt zu werden. -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="{loc:Loc sidebar.navigation}" Style="{StaticResource MutedText}"
                               FontSize="10.5" FontWeight="SemiBold" Margin="26,0,0,8"
                               Opacity="0.7" />
                    <RadioButton x:Name="NavDashboard" GroupName="Nav" Style="{StaticResource NavButton}"
                                 IsChecked="{Binding CurrentSection, Mode=TwoWay,
                                             Converter={StaticResource EnumToBool}, ConverterParameter=Uebersicht}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  Data="M3 3 H10 V10 H3 Z M14 3 H21 V8 H14 Z M14 12 H21 V21 H14 Z M3 14 H10 V21 H3 Z" />
                            <TextBlock Text="{loc:Loc nav.overview}" Margin="14,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavSystem" GroupName="Nav" Style="{StaticResource NavButton}"
                                 IsChecked="{Binding CurrentSection, Mode=TwoWay,
                                             Converter={StaticResource EnumToBool}, ConverterParameter=System}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  Data="M3 5 H21 V11 H3 Z M3 13 H21 V19 H3 Z M18 8 m -0.9 0 a 0.9 0.9 0 1 0 1.8 0 a 0.9 0.9 0 1 0 -1.8 0 M18 16 m -0.9 0 a 0.9 0.9 0 1 0 1.8 0 a 0.9 0.9 0 1 0 -1.8 0" />
                            <TextBlock Text="{loc:Loc nav.storage}" Margin="14,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <!-- Zusammengefasste Reinigungs-Gruppe: der Gruppenkopf klappt die beiden
                         Unterpunkte Bereinigung + Tiefenreinigung auf/zu. Die RadioButtons behalten
                         ihre Namen (NavCleaner/NavDeepClean) und Section-Bindings – die Content-Views
                         weiter unten hängen unverändert an deren IsChecked. -->
                    <ToggleButton x:Name="NavCleaningGroup" Style="{StaticResource NavGroupToggle}"
                                  IsChecked="{Binding IsCleaningExpanded, Mode=TwoWay}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                  Data="M6 2 L18 2 L18 6 L6 6 Z M8 6 L16 6 L15 21 L9 21 Z M11 9 L11 18 M14 9 L13 18" />
                            <TextBlock Text="{loc:Loc nav.cleaner}" Margin="14,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </ToggleButton>
                    <StackPanel Visibility="{Binding IsChecked, ElementName=NavCleaningGroup,
                                            Converter={StaticResource BoolToVis}}">
                        <RadioButton x:Name="NavCleaner" GroupName="Nav" Style="{StaticResource NavSubButton}"
                                     IsChecked="{Binding CurrentSection, Mode=TwoWay,
                                                 Converter={StaticResource EnumToBool}, ConverterParameter=Bereinigung}">
                            <TextBlock Text="{loc:Loc nav.cleaner}" VerticalAlignment="Center" />
                        </RadioButton>
                        <RadioButton x:Name="NavDeepClean" GroupName="Nav" Style="{StaticResource NavSubButton}"
                                     IsChecked="{Binding CurrentSection, Mode=TwoWay,
                                                 Converter={StaticResource EnumToBool}, ConverterParameter=Tiefenreinigung}">
                            <TextBlock Text="{loc:Loc nav.deepclean}" VerticalAlignment="Center" />
                        </RadioButton>
                    </StackPanel>
                    <RadioButton x:Name="NavStartup" GroupName="Nav" Style="{StaticResource NavButton}"
                                 IsChecked="{Binding CurrentSection, Mode=TwoWay,
                                             Converter={StaticResource EnumToBool}, ConverterParameter=Autostart}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  Data="M12 2 C14.5 4.5 16 8.5 16 13 L8 13 C8 8.5 9.5 4.5 12 2 Z M8 11.5 L5 15 L5.5 17.5 L8 15.8 Z M16 11.5 L19 15 L18.5 17.5 L16 15.8 Z M10 16 L12 21 L14 16 Z M12 7 m -1.6 0 a 1.6 1.6 0 1 0 3.2 0 a 1.6 1.6 0 1 0 -3.2 0" />
                            <TextBlock Text="{loc:Loc nav.startup}" Margin="14,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavContextMenu" GroupName="Nav" Style="{StaticResource NavButton}"
                                 IsChecked="{Binding CurrentSection, Mode=TwoWay,
                                             Converter={StaticResource EnumToBool}, ConverterParameter=Kontextmenue}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  Data="M4 3 H20 V21 H4 Z M7 7 H17 V9 H7 Z M7 11 H17 V13 H7 Z M7 15 H13 V17 H7 Z" />
                            <TextBlock Text="{loc:Loc nav.contextmenu}" Margin="14,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavPrivacy" GroupName="Nav" Style="{StaticResource NavButton}"
                                 IsChecked="{Binding CurrentSection, Mode=TwoWay,
                                             Converter={StaticResource EnumToBool}, ConverterParameter=Privatsphaere}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  Data="M12 2 L20 5 L20 11 C20 16 16 20 12 22 C8 20 4 16 4 11 L4 5 Z" />
                            <TextBlock Text="{loc:Loc nav.privacy}" Margin="14,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavNetwork" GroupName="Nav" Style="{StaticResource NavButton}"
                                 IsChecked="{Binding CurrentSection, Mode=TwoWay,
                                             Converter={StaticResource EnumToBool}, ConverterParameter=Netzwerk}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  Data="M12 2 C15 5 15 19 12 22 C9 19 9 5 12 2 Z M2 12 H22 M4.2 6.5 C6.5 8 17.5 8 19.8 6.5 M4.2 17.5 C6.5 16 17.5 16 19.8 17.5 M12 2 m -10 10 a 10 10 0 1 0 20 0 a 10 10 0 1 0 -20 0" />
                            <TextBlock Text="{loc:Loc nav.network}" Margin="14,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavUpdates" GroupName="Nav" Style="{StaticResource NavButton}"
                                 IsChecked="{Binding CurrentSection, Mode=TwoWay,
                                             Converter={StaticResource EnumToBool}, ConverterParameter=Updates}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  Data="M12 3 V14 M12 14 L8 10 M12 14 L16 10 M4 18 H20 V21 H4 Z" />
                            <TextBlock Text="{loc:Loc nav.updates}" Margin="14,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavSchedule" GroupName="Nav" Style="{StaticResource NavButton}"
                                 IsChecked="{Binding CurrentSection, Mode=TwoWay,
                                             Converter={StaticResource EnumToBool}, ConverterParameter=Zeitplan}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  Data="M12 2 A10 10 0 1 0 12 22 A10 10 0 1 0 12 2 Z M12 6 L12 12 L17 15" />
                            <TextBlock Text="{loc:Loc nav.schedule}" Margin="14,0,0,0" VerticalAlignment="Center" />
                            <!-- Schloss-Symbol (Segoe MDL2 Assets), solange Premium nicht freigeschaltet ist -->
                            <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                       Margin="8,0,0,0" VerticalAlignment="Center"
                                       Opacity="0.7" ToolTip="{loc:Loc premium.locked.title}"
                                       Visibility="{Binding IsScheduleUnlocked, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavUninstall" GroupName="Nav" Style="{StaticResource NavButton}"
                                 IsChecked="{Binding CurrentSection, Mode=TwoWay,
                                             Converter={StaticResource EnumToBool}, ConverterParameter=Deinstallation}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  Data="M5 6 H19 L18 21 H6 Z M9 3 H15 V6 H9 Z M10 10 V17 M14 10 V17" />
                            <TextBlock Text="{loc:Loc nav.uninstall}" Margin="14,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavDuplicates" GroupName="Nav" Style="{StaticResource NavButton}"
                                 IsChecked="{Binding CurrentSection, Mode=TwoWay,
                                             Converter={StaticResource EnumToBool}, ConverterParameter=Duplikate}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  Data="M8 8 H20 V20 H8 Z M4 4 H16 V6 H6 V16 H4 Z" />
                            <TextBlock Text="{loc:Loc nav.duplicates}" Margin="14,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavRestore" GroupName="Nav" Style="{StaticResource NavButton}"
                                 IsChecked="{Binding CurrentSection, Mode=TwoWay,
                                             Converter={StaticResource EnumToBool}, ConverterParameter=Wiederherstellen}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  Data="M4 12 A8 8 0 1 1 6.3 17.6 M4 18 L4 13 L9 13 M12 8 L12 12 L15 14" />
                            <TextBlock Text="{loc:Loc nav.restore}" Margin="14,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ================= Content ================= -->
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Integritäts-Banner (OPCL-20): nur sichtbar, wenn die Selbstprüfung der eigenen
                 EXE angeschlagen hat. Gelb, wenn nur gewarnt wird (unsignierter Eigenbau);
                 rot, wenn deswegen Funktionen gesperrt sind (manipulierte Signatur). -->
            <Border Grid.Row="0" Padding="16,10" BorderThickness="0,0,0,1"
                    BorderBrush="{StaticResource BorderBrush}"
                    Visibility="{Binding IsIntegrityDegraded, Converter={StaticResource BoolToVis}}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource WarnSoftBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsIntegrityBlocked}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource DangerSoftBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <Path Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"
                          Data="M12 2 L22 20 H2 Z M11 8 H13 V14 H11 Z M11 16 H13 V18 H11 Z">
                        <Path.Style>
                            <Style TargetType="Path">
                                <Setter Property="Fill" Value="{DynamicResource WarnBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsIntegrityBlocked}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource DangerBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>
                    <TextBlock Text="{Binding IntegrityBannerText}" Margin="12,0,0,0"
                               VerticalAlignment="Center" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextBrush}" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="1">
            <views:DashboardView DataContext="{Binding Dashboard}"
                                 Visibility="{Binding IsChecked, ElementName=NavDashboard, Converter={StaticResource BoolToVis}}" />
            <views:SystemView DataContext="{Binding Dashboard}"
                              Visibility="{Binding IsChecked, ElementName=NavSystem, Converter={StaticResource BoolToVis}}" />
            <views:CleanerView DataContext="{Binding Cleaner}"
                               Visibility="{Binding IsChecked, ElementName=NavCleaner, Converter={StaticResource BoolToVis}}" />
            <views:DeepCleanView DataContext="{Binding DeepClean}"
                                 Visibility="{Binding IsChecked, ElementName=NavDeepClean, Converter={StaticResource BoolToVis}}" />
            <views:StartupView DataContext="{Binding Startup}"
                               Visibility="{Binding IsChecked, ElementName=NavStartup, Converter={StaticResource BoolToVis}}" />
            <views:ContextMenuView DataContext="{Binding ContextMenu}"
                                   Visibility="{Binding IsChecked, ElementName=NavContextMenu, Converter={StaticResource BoolToVis}}" />
            <views:PrivacyView DataContext="{Binding Privacy}"
                               Visibility="{Binding IsChecked, ElementName=NavPrivacy, Converter={StaticResource BoolToVis}}" />
            <views:NetworkView DataContext="{Binding Network}"
                               Visibility="{Binding IsChecked, ElementName=NavNetwork, Converter={StaticResource BoolToVis}}" />
            <views:UpdaterView DataContext="{Binding Updater}"
                               Visibility="{Binding IsChecked, ElementName=NavUpdates, Converter={StaticResource BoolToVis}}" />
            <!-- Zeitplan: Premium-Modul-View oder Locked-Ansicht (siehe MainViewModel) -->
            <ContentControl Content="{Binding ScheduleSectionContent}" Focusable="False"
                            Visibility="{Binding IsChecked, ElementName=NavSchedule, Converter={StaticResource BoolToVis}}" />
            <views:UninstallView DataContext="{Binding Uninstall}"
                                 Visibility="{Binding IsChecked, ElementName=NavUninstall, Converter={StaticResource BoolToVis}}" />
            <views:DuplicatesView DataContext="{Binding Duplicates}"
                                  Visibility="{Binding IsChecked, ElementName=NavDuplicates, Converter={StaticResource BoolToVis}}" />
            <views:BackupHistoryView DataContext="{Binding BackupHistory}"
                                     Visibility="{Binding IsChecked, ElementName=NavRestore, Converter={StaticResource BoolToVis}}" />
            <!-- Der eigenständige Lizenz-Bereich (früher via Sidebar-Pro-Karte) ist entfernt;
                 Lizenz/Premium wird ausschließlich über den Einstellungsbereich (Zahnrad,
                 eingebettete LicenseView) verwaltet. MainViewModel.License bleibt als geteilte
                 Instanz für den Einstellungsbereich bestehen. -->
            <!-- Zentraler Einstellungsbereich (Zahnrad). Sichtbarkeit über IsSettings am MainViewModel;
                 der DataContext dieser View ist das SettingsViewModel, daher die Bindung an das
                 Fenster-DataContext (= MainViewModel) auflösen. -->
            <views:SettingsView DataContext="{Binding Settings}"
                                Visibility="{Binding DataContext.IsSettings, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}" />
            </Grid>
        </Grid>

        <!-- Cyberpunk-Scanline: feines, nicht interaktives Linienraster; bei Cyberpunk stets sichtbar.
             Der langsame vertikale Scroll (ScanlineShift) läuft nur ohne „Animationen reduzieren";
             bei ReduceMotion bleibt die Scanline statisch sichtbar. -->
        <Rectangle x:Name="ScanlineOverlay" Grid.Row="0" Grid.RowSpan="2"
                   Grid.Column="0" Grid.ColumnSpan="2"
                   IsHitTestVisible="False" Visibility="Collapsed" Opacity="0.13">
            <Rectangle.Fill>
                <DrawingBrush TileMode="Tile" Viewport="0,0,3,3" ViewportUnits="Absolute"
                              Viewbox="0,0,3,3" ViewboxUnits="Absolute">
                    <DrawingBrush.Transform>
                        <TranslateTransform x:Name="ScanlineShift" />
                    </DrawingBrush.Transform>
                    <DrawingBrush.Drawing>
                        <GeometryDrawing Brush="#FFFFFFFF">
                            <GeometryDrawing.Geometry>
                                <RectangleGeometry Rect="0,0,3,1" />
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Rectangle.Fill>
        </Rectangle>
    </Grid>
</Window>
