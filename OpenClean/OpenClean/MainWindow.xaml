<Window x:Class="OpenClean.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OpenClean"
        xmlns:views="clr-namespace:OpenClean.Views"
        xmlns:loc="clr-namespace:OpenClean.Services.Localization"
        mc:Ignorable="d"
        Title="OpenClean" Height="760" Width="1180"
        MinHeight="620" MinWidth="980"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterScreen"
        FontFamily="{StaticResource AppFont}">
    <!-- Eigene Titelleiste: Standard-Chrome ausblenden, Drag/Resize/Snap bleiben erhalten -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" ResizeBorderThickness="6"
                      GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <views:EnumToBoolConverter x:Key="EnumToBool" />
    </Window.Resources>
    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="248" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ================= Titelleiste (Inhalt-Spalte) ================= -->
        <Grid Grid.Row="0" Grid.Column="1" Background="{DynamicResource BgBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <Button Style="{StaticResource WindowControlButton}" Click="MinimizeButton_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True" ToolTip="{loc:Loc titlebar.minimize}">
                    <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                </Button>
                <Button Style="{StaticResource WindowControlButton}" Click="MaximizeButton_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True" ToolTip="{loc:Loc titlebar.maximize}">
                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10"
                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="&#xE922;" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Value="Maximized">
                                        <Setter Property="Text" Value="&#xE923;" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>
                <Button Style="{StaticResource WindowCloseButton}" Click="CloseButton_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True" ToolTip="{loc:Loc titlebar.close}">
                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- ================= Sidebar ================= -->
        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Background="{DynamicResource BgDeepBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Brand -->
                <StackPanel DockPanel.Dock="Top" Margin="22,26,20,20">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="34" Height="34" CornerRadius="9" Background="{DynamicResource AccentBrush}"
                                VerticalAlignment="Center">
                            <Path Data="M 0,6 L 4,10 L 12,0" Stroke="#FF10261F" StrokeThickness="2.4"
                                  Stretch="Uniform" Margin="8" StrokeEndLineCap="Round" StrokeStartLineCap="Round" />
                        </Border>
                        <TextBlock Text="{Binding AppTitle}" FontSize="21" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="12,0,0,0" />
                    </StackPanel>
                    <TextBlock Text="{Binding AppTagline}" Style="{StaticResource MutedText}"
                               TextWrapping="Wrap" FontSize="11.5" Margin="1,12,0,0" LineHeight="17" />
                </StackPanel>

                <!-- Footer -->
                <StackPanel DockPanel.Dock="Bottom" Margin="24,0,20,18">
                    <Border Height="1" Background="{DynamicResource BorderBrush}"
                            Opacity="0.6" Margin="0,0,0,14" />
                    <StackPanel Orientation="Horizontal">
                        <ToggleButton x:Name="ThemeToggle" Style="{StaticResource ToggleSwitch}"
                                      VerticalAlignment="Center" Click="ThemeToggle_Click"
                                      ToolTip="{loc:Loc theme.toggleTooltip}" />
                        <TextBlock x:Name="ThemeLabel"
                                   FontFamily="{StaticResource AppFont}" FontSize="13"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource TextBrush}"
                                   VerticalAlignment="Center" Margin="12,0,0,0" />
                    </StackPanel>

                    <!-- Sprachauswahl -->
                    <TextBlock Text="{loc:Loc sidebar.language}" Style="{StaticResource MutedText}"
                               FontSize="10.5" FontWeight="SemiBold" Opacity="0.7" Margin="1,16,0,6" />
                    <ComboBox Style="{StaticResource LanguageCombo}"
                              ItemsSource="{Binding Languages, Source={x:Static loc:LocalizationManager.Instance}}"
                              SelectedItem="{Binding CurrentLanguageOption, Source={x:Static loc:LocalizationManager.Instance}, Mode=TwoWay}" />

                    <TextBlock Text="{loc:Loc sidebar.version}" Style="{StaticResource MutedText}"
                               FontSize="11" Margin="1,14,0,0" />
                </StackPanel>

                <!-- Nav -->
                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="{loc:Loc sidebar.navigation}" Style="{StaticResource MutedText}"
                               FontSize="10.5" FontWeight="SemiBold" Margin="26,0,0,8"
                               Opacity="0.7" />
                    <RadioButton x:Name="NavDashboard" GroupName="Nav" Style="{StaticResource NavButton}"
                                 IsChecked="{Binding CurrentSection, Mode=TwoWay,
                                             Converter={StaticResource EnumToBool}, ConverterParameter=Uebersicht}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  Data="M3 3 H10 V10 H3 Z M14 3 H21 V8 H14 Z M14 12 H21 V21 H14 Z M3 14 H10 V21 H3 Z" />
                            <TextBlock Text="{loc:Loc nav.overview}" Margin="14,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavSystem" GroupName="Nav" Style="{StaticResource NavButton}"
                                 IsChecked="{Binding CurrentSection, Mode=TwoWay,
                                             Converter={StaticResource EnumToBool}, ConverterParameter=System}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  Data="M4 4 H20 V11 H4 Z M4 13 H20 V20 H4 Z M7 7.5 H7.01 M7 16.5 H7.01" />
                            <TextBlock Text="{loc:Loc nav.storage}" Margin="14,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavCleaner" GroupName="Nav" Style="{StaticResource NavButton}"
                                 IsChecked="{Binding CurrentSection, Mode=TwoWay,
                                             Converter={StaticResource EnumToBool}, ConverterParameter=Bereinigung}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  Data="M6 2 L18 2 L18 6 L6 6 Z M8 6 L16 6 L15 21 L9 21 Z M11 9 L11 18 M14 9 L13 18" />
                            <TextBlock Text="{loc:Loc nav.cleaner}" Margin="14,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavStartup" GroupName="Nav" Style="{StaticResource NavButton}"
                                 IsChecked="{Binding CurrentSection, Mode=TwoWay,
                                             Converter={StaticResource EnumToBool}, ConverterParameter=Autostart}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  Data="M12 3 L14 9 L20 9 L15 13 L17 20 L12 16 L7 20 L9 13 L4 9 L10 9 Z" />
                            <TextBlock Text="{loc:Loc nav.startup}" Margin="14,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavPrivacy" GroupName="Nav" Style="{StaticResource NavButton}"
                                 IsChecked="{Binding CurrentSection, Mode=TwoWay,
                                             Converter={StaticResource EnumToBool}, ConverterParameter=Privatsphaere}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  Data="M12 2 L20 5 L20 11 C20 16 16 20 12 22 C8 20 4 16 4 11 L4 5 Z" />
                            <TextBlock Text="{loc:Loc nav.privacy}" Margin="14,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavUpdates" GroupName="Nav" Style="{StaticResource NavButton}"
                                 IsChecked="{Binding CurrentSection, Mode=TwoWay,
                                             Converter={StaticResource EnumToBool}, ConverterParameter=Updates}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  Data="M12 3 V14 M12 14 L8 10 M12 14 L16 10 M4 18 H20 V21 H4 Z" />
                            <TextBlock Text="{loc:Loc nav.updates}" Margin="14,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ================= Content ================= -->
        <Grid Grid.Row="1" Grid.Column="1">
            <views:DashboardView DataContext="{Binding Dashboard}"
                                 Visibility="{Binding IsChecked, ElementName=NavDashboard, Converter={StaticResource BoolToVis}}" />
            <views:SystemView DataContext="{Binding Dashboard}"
                              Visibility="{Binding IsChecked, ElementName=NavSystem, Converter={StaticResource BoolToVis}}" />
            <views:CleanerView DataContext="{Binding Cleaner}"
                               Visibility="{Binding IsChecked, ElementName=NavCleaner, Converter={StaticResource BoolToVis}}" />
            <views:StartupView DataContext="{Binding Startup}"
                               Visibility="{Binding IsChecked, ElementName=NavStartup, Converter={StaticResource BoolToVis}}" />
            <views:PrivacyView DataContext="{Binding Privacy}"
                               Visibility="{Binding IsChecked, ElementName=NavPrivacy, Converter={StaticResource BoolToVis}}" />
            <views:UpdaterView DataContext="{Binding Updater}"
                               Visibility="{Binding IsChecked, ElementName=NavUpdates, Converter={StaticResource BoolToVis}}" />
        </Grid>
    </Grid>
</Window>
